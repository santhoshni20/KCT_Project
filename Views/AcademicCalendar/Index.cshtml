@{
    ViewData["Title"] = "Batch Calendar";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<style>
    .page-container {
        margin-top: 80px;
        text-align: center;
    }

    .batch-section {
        margin-bottom: 50px;
    }

    .batch-label {
        font-size: 1.1rem;
        font-weight: 600;
        margin-right: 10px;
    }

    .download-btn {
        font-size: 1.1rem;
        font-weight: 600;
        background-color: #007bff;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: background 0.3s;
    }

        .download-btn:hover {
            background-color: #0056b3;
        }
</style>

<div class="container page-container">
    <!-- Batch Dropdown -->
    <div class="batch-section d-flex justify-content-center align-items-center">
        <label class="batch-label">Batch</label>
        <select class="form-select w-auto" id="batchDropdown">
            <option value="">-- Select Batch --</option>
            <option value="Batch1">2022 - 2026</option>
            <option value="Batch2">2023 - 2027</option>
            <option value="Batch3">2024 - 2028</option>
            <option value="Batch3">2024 - 2028</option>
        </select>
    </div>

    <!-- Download Calendar -->
    <div>
        <button class="download-btn">
            <i class="fas fa-download"></i> Download Calendar
        </button>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.querySelector(".download-btn").addEventListener("click", function () {
            var batch = document.getElementById("batchDropdown").value;
            if (!batch) {
                alert("Please select a batch before downloading!");
                return;
            }
            // Example: Call your API for downloading calendar
            window.location.href = "/Calendar/Download?batch=" + batch;
        });
    </script>
}
