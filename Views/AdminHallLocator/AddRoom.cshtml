@model mstRoom
@{
    ViewData["Title"] = "Add Hall";
    var blocks = ViewBag.Blocks as List<mstBlock>;
}

<div class="container mt-4">
    <h4 class="fw-bold mb-3">Add New Hall</h4>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="AddRoom" method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Block</label>
                    <select asp-for="blockId" class="form-select" required>
                        <option value="">-- Select Block --</option>
                        @if (blocks != null)
                        {
                            foreach (var block in blocks)
                            {
                                <option value="@block.blockId">@block.blockName</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="blockId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Hall Number</label>
                    <input asp-for="roomNumber"
                           type="text"
                           class="form-control"
                           placeholder="e.g., C203"
                           required />
                    <span asp-validation-for="roomNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Total Desks</label>
                    <input asp-for="totalDesks"
                           type="number"
                           class="form-control"
                           min="1"
                           required />
                    <span asp-validation-for="totalDesks" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Seats Per Desk</label>
                    <input asp-for="seatsPerDesk"
                           type="number"
                           value="2"
                           class="form-control"
                           min="1"
                           max="4" />
                    <span asp-validation-for="seatsPerDesk" class="text-danger"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Save Hall
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}