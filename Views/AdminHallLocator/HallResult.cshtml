@model HallLocatorDTO
@{
    ViewData["Title"] = "Hall Details";
}

<div class="container mt-4">
    <h4 class="fw-bold mb-3">Hall Details</h4>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-bordered">
                <tr>
                    <th width="30%">Block</th>
                    <td>@Model.blockName</td>
                </tr>
                <tr>
                    <th>Hall Number</th>
                    <td>@Model.roomNumber</td>
                </tr>
                <tr>
                    <th>Total Desks</th>
                    <td>@Model.totalDesks</td>
                </tr>
                <tr>
                    <th>Seats Per Desk</th>
                    <td>@Model.seatsPerDesk</td>
                </tr>
                <tr>
                    <th>Total Seats</th>
                    <td class="fw-bold">@Model.totalSeats</td>
                </tr>
                <tr>
                    <th>Occupied Seats</th>
                    <td class="text-danger fw-bold">@Model.occupiedSeats</td>
                </tr>
                <tr>
                    <th>Remaining Seats</th>
                    <td class="text-success fw-bold">@Model.remainingSeats</td>
                </tr>
            </table>

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
                <a asp-action="AddRoom" class="btn btn-success">
                    <i class="bi bi-plus-circle"></i> Add Another Hall
                </a>
            </div>
        </div>
    </div>
</div>