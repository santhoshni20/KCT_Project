@model List<mstBlock>
@{
    ViewData["Title"] = "Hall Locator - Admin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold">Hall Locator (Admin)</h4>
        <a asp-action="AddRoom" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add New Hall
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="LocateHall" method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Select Block</label>
                    <select name="blockId" class="form-select" required>
                        <option value="">-- Select Block --</option>
                        @foreach (var block in Model)
                        {
                            <option value="@block.blockId">@block.blockName</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Hall Number</label>
                    <input type="text"
                           name="hallNumber"
                           class="form-control"
                           placeholder="e.g., C203"
                           required />
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Locate Hall
                </button>
            </form>
        </div>
    </div>
</div>