@model KSI_Project.Models.DTOs.AddDishDto
@{
    ViewData["Title"] = "Add Dish - " + ViewBag.CanteenName;
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }

    .add-dish-container {
        max-width: 700px;
        margin: 40px auto;
        padding: 20px;
    }

    .form-card {
        background: white;
        border-radius: 15px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

        .form-card h1 {
            color: #333;
            text-align: center;
            margin-bottom: 30px;
        }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        font-weight: 600;
        display: block;
        margin-bottom: 8px;
    }

    input[type="text"], input[type="number"], select {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        border: 1px solid #ccc;
    }

    .btn-submit {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 12px 25px;
        border-radius: 10px;
        width: 100%;
        font-weight: bold;
    }

        .btn-submit:hover {
            transform: scale(1.03);
        }
</style>

<div class="add-dish-container">
    <div class="form-card">
        <h1>Add Dish to @ViewBag.CanteenName</h1>

        <form asp-action="@(Model.ItemID > 0 ? "EditDish" : "AddDish")" method="post">
            @Html.AntiForgeryToken()

            <!-- Hidden fields -->
            <input type="hidden" asp-for="ItemID" />
            <input type="hidden" asp-for="CanteenID" value="@ViewBag.CanteenId" />

            <div class="form-group">
                <label asp-for="DishName"></label>
                <input asp-for="DishName" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Availability"></label>
                <select asp-for="Availability" class="form-control">
                    <option value="Yes">Available</option>
                    <option value="No">Unavailable</option>
                </select>
            </div>

            <div class="form-group">
                <label asp-for="Price"></label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" />
            </div>

            <div class="form-group">
                <label>Available Times</label><br />
                <input type="checkbox" asp-for="Morning" /> Morning
                <input type="checkbox" asp-for="Afternoon" /> Afternoon
                <input type="checkbox" asp-for="Evening" /> Evening
                <input type="checkbox" asp-for="Snacks" /> Snacks
            </div>

            <button type="submit" class="btn-submit">
                @(Model.ItemID > 0 ? "Update Dish" : "Add Dish")
            </button>
        </form>

    </div>
</div>
<form asp-action="@(Model.ItemID > 0 ? "EditDish" : "AddDish")" method="post">
    @Html.AntiForgeryToken()

    <!-- ✅ Add validation summary -->
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <!-- Hidden fields -->
    <input type="hidden" asp-for="ItemID" />
    <input type="hidden" asp-for="CanteenID" value="@ViewBag.CanteenId" />

    <div class="form-group">
        <label asp-for="DishName"></label>
        <input asp-for="DishName" class="form-control" />
        <span asp-validation-for="DishName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Availability"></label>
        <select asp-for="Availability" class="form-control">
            <option value="">-- Select --</option>
            <option value="Yes">Available</option>
            <option value="No">Unavailable</option>
        </select>
        <span asp-validation-for="Availability" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Available Times</label><br />
        <input type="checkbox" asp-for="Morning" /> Morning
        <input type="checkbox" asp-for="Afternoon" /> Afternoon
        <input type="checkbox" asp-for="Evening" /> Evening
        <input type="checkbox" asp-for="Snacks" /> Snacks
    </div>

    <button type="submit" class="btn-submit">
        @(Model.ItemID > 0 ? "Update Dish" : "Add Dish")
    </button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}