@model IEnumerable<KSI_Project.Models.Entity.Canteen>

@{
    ViewData["Title"] = "Dish Management";
    var canteens = ViewBag.Canteens as IEnumerable<KSI_Project.Models.Entity.CanteenId> ?? new List<KSI_Project.Models.Entity.CanteenId>();
}

<div class="container mt-4">

    <h2 class="mb-4">🍴 Dish Management</h2>

    <!-- Success / Error Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Add Dish -->
    <div class="card mb-4">
        <div class="card-header fw-bold">Add New Dish</div>
        <div class="card-body">
            <form asp-action="AddDish" asp-controller="Canteen" method="post">
                @Html.AntiForgeryToken()

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Canteen</label>
                        <select name="CanteenID" class="form-select" required>
                            <option value="">Select Canteen</option>
                            @foreach (var canteen in canteens.Where(c => c.IsActive))
                            {
                                <option value="@canteen.CanteenID">@canteen.CanteenName</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Dish Name</label>
                        <input type="text" name="DishName" class="form-control" placeholder="Enter Dish Name" required />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Price</label>
                        <input type="number" name="Price" class="form-control" placeholder="Enter Price" step="0.01" min="0" required />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Availability</label>
                        <select name="Availability" class="form-select" required>
                            <option value="yes">Yes</option>
                            <option value="no">No</option>
                        </select>
                    </div>

                    <div class="col-md-8">
                        <label class="form-label">Available Time (Select Multiple)</label>
                        <div class="d-flex gap-3 mt-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="Morning" id="morning" value="true">
                                <label class="form-check-label" for="morning">Morning</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="Afternoon" id="afternoon" value="true">
                                <label class="form-check-label" for="afternoon">Afternoon</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="Evening" id="evening" value="true">
                                <label class="form-check-label" for="evening">Evening</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="Snacks" id="snacks" value="true">
                                <label class="form-check-label" for="snacks">Snacks</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <button type="submit" class="btn btn-primary">➕ Add Dish</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Dish List -->
    <div class="card">
        <div class="card-header fw-bold">Dish List</div>
        <div class="card-body">

            @if (Model == null || !Model.Any())
            {
                <p class="text-muted">No dishes available.</p>
            }
            else
            {
                <table class="table table-bordered table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th style="width:5%">#</th>
                            <th style="width:15%">Canteen</th>
                            <th style="width:20%">Dish Name</th>
                            <th style="width:8%">Price</th>
                            <th style="width:10%">Availability</th>
                            <th style="width:20%">Available Time</th>
                            <th style="width:10%">Status</th>
                            <th style="width:12%">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dish in Model)
                        {
                            <tr>
                                <td>@dish.ItemID</td>
                                <td>@dish.CanteenDetails?.CanteenName</td>
                                <td>@dish.DishName</td>
                                <td>₹@dish.Price.ToString("0.00")</td>
                                <td>
                                    <span class="badge @(dish.Availability == "yes" ? "bg-success" : "bg-danger")">
                                        @dish.Availability.ToUpper()
                                    </span>
                                </td>
                                <td>
                                    @if (dish.Morning)
                                    {
                                        <span class="badge bg-info me-1">Morning</span>
                                    }
                                    @if (dish.Afternoon)
                                    {
                                        <span class="badge bg-warning me-1">Afternoon</span>
                                    }
                                    @if (dish.Evening)
                                    {
                                        <span class="badge bg-primary me-1">Evening</span>
                                    }
                                    @if (dish.Snacks)
                                    {
                                        <span class="badge bg-secondary me-1">Snacks</span>
                                    }
                                </td>
                                <td>
                                    <!-- Toggle Switch -->
                                    <form asp-action="ToggleDishStatus"
                                          asp-controller="Canteen"
                                          method="post"
                                          style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@dish.ItemID" />
                                        <div class="form-check form-switch d-inline-block">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                            @(dish.IsActive ? "checked" : "")
                                                   onchange="this.form.submit()"
                                                   style="cursor: pointer; width: 50px; height: 24px;">
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    <!-- Edit Button -->
                                    <button class="btn btn-sm btn-warning"
                                            onclick="openEditModal(@dish.ItemID, @dish.CanteenID, '@dish.DishName', @dish.Price, '@dish.Availability', @dish.Morning.ToString().ToLower(), @dish.Afternoon.ToString().ToLower(), @dish.Evening.ToString().ToLower(), @dish.Snacks.ToString().ToLower())">
                                        ✏️
                                    </button>

                                    <!-- Delete Button -->
                                    <form asp-action="DeleteDish"
                                          asp-controller="Canteen"
                                          method="post"
                                          style="display:inline"
                                          onsubmit="return confirm('Are you sure you want to delete this dish?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@dish.ItemID" />
                                        <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editDishModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="EditDish" asp-controller="Canteen" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header">
                    <h5 class="modal-title">Edit Dish</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="ItemID" id="editItemId" />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Canteen</label>
                            <select name="CanteenID" id="editCanteenId" class="form-select" required>
                                <option value="">Select Canteen</option>
                                @foreach (var canteen in canteens.Where(c => c.IsActive))
                                {
                                    <option value="@canteen.CanteenID">@canteen.CanteenName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Dish Name</label>
                            <input type="text" name="DishName" id="editDishName" class="form-control" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Price</label>
                            <input type="number" name="Price" id="editPrice" class="form-control" step="0.01" min="0" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Availability</label>
                            <select name="Availability" id="editAvailability" class="form-select" required>
                                <option value="yes">Yes</option>
                                <option value="no">No</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label">Available Time (Select Multiple)</label>
                            <div class="d-flex gap-3 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="Morning" id="editMorning" value="true">
                                    <label class="form-check-label" for="editMorning">Morning</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="Afternoon" id="editAfternoon" value="true">
                                    <label class="form-check-label" for="editAfternoon">Afternoon</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="Evening" id="editEvening" value="true">
                                    <label class="form-check-label" for="editEvening">Evening</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="Snacks" id="editSnacks" value="true">
                                    <label class="form-check-label" for="editSnacks">Snacks</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Update</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditModal(itemId, canteenId, dishName, price, availability, morning, afternoon, evening, snacks) {
                 document.getElementById("editItemId").value = itemId;
        document.getElementById("editCanteenId").value = canteenId;
        document.getElementById("editDishName").value = dishName; // ⚠️ Risk of XSS if dishName contains quotes
        document.getElementById("editPrice").value = price;
        document.getElementById("editAvailability").value = availability;

            document.getElementById("editMorning").checked = morning;
            document.getElementById("editAfternoon").checked = afternoon;
            document.getElementById("editEvening").checked = evening;
            document.getElementById("editSnacks").checked = snacks;

            var modal = new bootstrap.Modal(document.getElementById('editDishModal'));
            modal.show();
        }
    </script>
}