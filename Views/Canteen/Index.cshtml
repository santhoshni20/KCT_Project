                            @Html.Raw("🍱")
                            ; break;
                        case 5:
                            @Html.Raw("🍛")
                            ; break;
                        case 6:
                            @Html.Raw("🫖")
                            ; break;
                        default:
                            @Html.Raw("🍽")
