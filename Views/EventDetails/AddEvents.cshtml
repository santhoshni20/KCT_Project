@{
    Layout = "_Layout";
    ViewData["Title"] = "Add Event";
}

<div class="d-flex justify-content-between mb-3">
    <h4 class="fw-bold">Event Details</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#eventModal">
        <i class="bx bx-plus"></i> Add Event
    </button>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table" id="eventsTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Event Name</th>
                    <th>Organised By</th>
                    <th>Event Date</th>
                    <th>Contact</th>
                    <th>Description</th>
                    <th>Brochure</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Event</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <!-- FORM WRAPPER -->
                <form id="eventForm">
                    <div class="mb-2">
                        <label>Enter Event Name:</label>
                        <input id="eventName" class="form-control" placeholder="Event Name" />
                    </div>

                    <div class="mb-2">
                        <label>Organised By:</label>
                        <input id="organisedBy" class="form-control" placeholder="Organised By" />
                    </div>

                    <div class="mb-2">
                        <label>Event Date:</label>
                        <input type="date" id="eventDate" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label>Registration Deadline:</label>
                        <input type="date" id="registrationDeadline" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label>Contact Number:</label>
                        <input id="contactNumber" class="form-control" placeholder="Contact Number" />
                    </div>

                    <div class="mb-2">
                        <label>Brochure Image:</label>
                        <input type="file" id="brochureImage" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label>Description:</label>
                        <textarea id="description" class="form-control" rows="3"></textarea>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" onclick="saveEvent()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadEvents() {
            $.get('@Url.Action("GetAllEvents", "EventDetails")', function (res) {
                let rows = '';
                res.data.forEach((e, i) => {
                    rows += `<tr>
                        <td>${i + 1}</td>
                        <td>${e.eventName}</td>
                        <td>${e.organisedBy}</td>
                        <td>${new Date(e.eventDate).toLocaleDateString()}</td>
                        <td>${e.contactNumber}</td>
                        <td>${e.description ?? ''}</td>
                        <td>${e.brochureImagePath
                            ? `<a href="${e.brochureImagePath}" target="_blank">View</a>`
                            : ''}</td>
                    </tr>`;
                });
                $('#eventsTable tbody').html(rows);
            });
        }

        function saveEvent() {
            var formData = new FormData();
            formData.append("eventName", $('#eventName').val());
            formData.append("organisedBy", $('#organisedBy').val());
            formData.append("eventDate", $('#eventDate').val());
            formData.append("registrationDeadline", $('#registrationDeadline').val());
            formData.append("contactNumber", $('#contactNumber').val());
            formData.append("description", $('#description').val());

            var fileInput = $('#brochureImage')[0];
            if (fileInput.files.length > 0) {
                formData.append("brochureImage", fileInput.files[0]);
            }

            $.ajax({
                url: '@Url.Action("AddEvent", "EventDetails")',
                type: 'POST',
                processData: false,
                contentType: false,
                data: formData,
                success: function () {
                    $('#eventForm')[0].reset();     // ✅ CLEAR FORM
                    $('#eventModal').modal('hide');
                    loadEvents();
                }
            });
        }

        // Extra safety: clear form when modal closes
        $('#eventModal').on('hidden.bs.modal', function () {
            $('#eventForm')[0].reset();
        });

        $(document).ready(loadEvents);
    </script>
}
