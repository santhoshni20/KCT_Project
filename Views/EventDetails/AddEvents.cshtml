@{
    Layout = "_Layout"; // Or the layout file you are using for BINI UI
    ViewData["Title"] = "Add Event";
}

<div class="d-flex justify-content-between mb-3">
    <h4 class="fw-bold">Event Details</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#eventModal">
        <i class="bx bx-plus"></i> Add Event
    </button>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table" id="eventsTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Event Name</th>
                    <th>Organised By</th>
                    <th>Event Date</th>
                    <th>Contact</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5>Add Event</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input id="eventName" class="form-control mb-2" placeholder="Event Name" />
                <input id="organisedBy" class="form-control mb-2" placeholder="Organised By" />
                <input type="date" id="registrationDeadline" class="form-control mb-2" />
                <input type="date" id="eventDate" class="form-control mb-2" />
                <input id="contactNumber" class="form-control mb-2" placeholder="Contact Number" />
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" onclick="saveEvent()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadEvents() {
            $.get('@Url.Action("getAllEvents", "EventDetails")', function (res) {
                let rows = '';
                res.data.forEach((e, i) => {
                    rows += `<tr>
                        <td>${i + 1}</td>
                        <td>${e.eventName}</td>
                        <td>${e.organisedBy}</td>
                        <td>${new Date(e.eventDate).toLocaleDateString()}</td>
                        <td>${e.contactNumber}</td>
                    </tr>`;
                });
                $('#eventsTable tbody').html(rows);
            });
        }

        function saveEvent() {
            const data = {
                eventName: $('#eventName').val(),
                organisedBy: $('#organisedBy').val(),
                registrationDeadline: $('#registrationDeadline').val(),
                eventDate: $('#eventDate').val(),
                contactNumber: $('#contactNumber').val()
            };

            $.ajax({
                url: '@Url.Action("addEvent", "EventDetails")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function () {
                    $('#eventModal').modal('hide');
                    loadEvents();
                }
            });
        }

        $(document).ready(loadEvents);
    </script>
}
