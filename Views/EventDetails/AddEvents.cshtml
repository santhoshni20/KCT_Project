@{
    Layout = "_Layout";
    ViewData["Title"] = "Add Event";
}

<div class="d-flex justify-content-between mb-3">
    <h4 class="fw-bold">Event Details</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#eventModal">
        <i class="bx bx-plus"></i> Add Event
    </button>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table" id="eventsTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Event Name</th>
                    <th>Organised By</th>
                    <th>Event Date</th>
                    <th>Contact</th>
                    <th>Description</th>
                    <th>Brochure</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- ADD EVENT MODAL -->
<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Event</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="eventForm">
                    <div class="mb-2">
                        <label>Enter Event Name:</label>
                        <input id="eventName" class="form-control" placeholder="Event Name" />
                    </div>
                    <div class="mb-2">
                        <label>Organised By:</label>
                        <select id="organisedBy" class="form-control">
                            <option value="">Select Club</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label>Event Date:</label>
                        <input type="date" id="eventDate" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label>Registration Deadline:</label>
                        <input type="date" id="registrationDeadline" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label>Contact Number:</label>
                        <input id="contactNumber" class="form-control" placeholder="Contact Number" />
                    </div>
                    <div class="mb-2">
                        <label>Brochure Image:</label>
                        <input type="file" id="brochureImage" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label>Description:</label>
                        <textarea id="description" class="form-control" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" onclick="saveEvent()">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- EDIT EVENT MODAL -->
<div class="modal fade" id="editEventModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Event</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editEventForm">
                    <input type="hidden" id="editEventId" />
                    <div class="mb-2">
                        <label>Event Name:</label>
                        <input id="editEventName" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label>Organised By:</label>
                        <select id="editOrganisedBy" class="form-control">
                            <option value="">Select Club</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label>Event Date:</label>
                        <input type="date" id="editEventDate" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label>Registration Deadline:</label>
                        <input type="date" id="editRegistrationDeadline" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label>Contact Number:</label>
                        <input id="editContactNumber" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label>Brochure Image (leave empty to keep existing):</label>
                        <input type="file" id="editBrochureImage" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label>Description:</label>
                        <textarea id="editDescription" class="form-control" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-success" onclick="updateEvent()">Update</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadEvents() {
            $.get('@Url.Action("GetAllEvents", "EventDetails")', function (res) {
                let rows = '';
                res.data.forEach((e, i) => {
                    rows += `<tr>
                        <td>${i + 1}</td>
                        <td>${e.eventName}</td>
                        <td>${e.organisedBy}</td>
                        <td>${new Date(e.eventDate).toLocaleDateString()}</td>
                        <td>${e.contactNumber}</td>
                        <td>${e.description ?? ''}</td>
                        <td>${e.brochureImagePath
                            ? `<a href="${e.brochureImagePath}" target="_blank">View</a>`
                            : ''}</td>
                        <td>
                            <button class="btn btn-sm btn-warning" onclick="openEditEvent(${e.mstEventId}, '${e.eventName}', '${e.organisedBy}', '${e.eventDate?.split('T')[0]}', '${e.registrationDeadline?.split('T')[0]}', '${e.contactNumber}', '${e.description ?? ''}')">
                                <i class="bx bx-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="deleteEvent(${e.mstEventId})">
                                <i class="bx bx-trash"></i>
                            </button>
                        </td>
                    </tr>`;
                });
                $('#eventsTable tbody').html(rows);
            });
        }

        function saveEvent() {
            var formData = new FormData();
            formData.append("eventName", $('#eventName').val());
            formData.append("organisedBy", $('#organisedBy').val());
            formData.append("eventDate", $('#eventDate').val());
            formData.append("registrationDeadline", $('#registrationDeadline').val());
            formData.append("contactNumber", $('#contactNumber').val());
            formData.append("description", $('#description').val());
            var fileInput = $('#brochureImage')[0];
            if (fileInput.files.length > 0) formData.append("brochureImage", fileInput.files[0]);

            $.ajax({
                url: '@Url.Action("AddEvent", "EventDetails")',
                type: 'POST', processData: false, contentType: false, data: formData,
                success: function () {
                    $('#eventForm')[0].reset();
                    $('#eventModal').modal('hide');
                    loadEvents();
                }
            });
        }

        function openEditEvent(id, name, organisedBy, eventDate, regDeadline, contact, desc) {
            $('#editEventId').val(id);
            $('#editEventName').val(name);
            $('#editEventDate').val(eventDate);
            $('#editRegistrationDeadline').val(regDeadline);
            $('#editContactNumber').val(contact);
            $('#editDescription').val(desc);

            $.get('@Url.Action("getAllClubs", "EventDetails")', function (res) {
                let options = '<option value="">Select Club</option>';
                res.data.forEach(c => {
                    const selected = c.clubName === organisedBy ? 'selected' : '';
                    options += `<option value="${c.clubName}" ${selected}>${c.clubName}</option>`;
                });
                $('#editOrganisedBy').html(options);
            });

            $('#editEventModal').modal('show');
        }

        function updateEvent() {
            var formData = new FormData();
            formData.append("mstEventId", $('#editEventId').val());
            formData.append("eventName", $('#editEventName').val());
            formData.append("organisedBy", $('#editOrganisedBy').val());
            formData.append("eventDate", $('#editEventDate').val());
            formData.append("registrationDeadline", $('#editRegistrationDeadline').val());
            formData.append("contactNumber", $('#editContactNumber').val());
            formData.append("description", $('#editDescription').val());
            var fileInput = $('#editBrochureImage')[0];
            if (fileInput.files.length > 0) formData.append("brochureImage", fileInput.files[0]);

            $.ajax({
                url: '@Url.Action("UpdateEvent", "EventDetails")',
                type: 'POST', processData: false, contentType: false, data: formData,
                success: function (res) {
                    if (res.statusCode === 200) {
                        $('#editEventModal').modal('hide');
                        loadEvents();
                    }
                }
            });
        }

        function deleteEvent(id) {
            if (!confirm('Are you sure you want to delete this event?')) return;
            $.post('@Url.Action("DeleteEvent", "EventDetails")', { id }, function (res) {
                if (res.statusCode === 200) loadEvents();
            });
        }

        function loadClubsDropdown() {
            $.get('@Url.Action("getAllClubs", "EventDetails")', function (res) {
                if (res.statusCode !== 200) return;
                let options = '<option value="">Select Club</option>';
                res.data.forEach(c => {
                    options += `<option value="${c.clubName}">${c.clubName}</option>`;
                });
                $('#organisedBy').html(options);
            });
        }

        $('#eventModal').on('hidden.bs.modal', function () {
            $('#eventForm')[0].reset();
            loadClubsDropdown();
        });

        $(document).ready(function () {
            loadEvents();
            loadClubsDropdown();
        });
    </script>
}