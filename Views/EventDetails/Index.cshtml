@{
    ViewData["Title"] = "Event Details";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<style>
    .event-section {
        margin-bottom: 40px;
    }

    .event-slider {
        display: flex;
        overflow-x: auto;
        gap: 20px;
        padding-bottom: 10px;
        scrollbar-width: thin;
    }

        .event-slider::-webkit-scrollbar {
            height: 8px;
        }

        .event-slider::-webkit-scrollbar-thumb {
            background: #555;
            border-radius: 4px;
        }

    .event-card {
        flex: 0 0 auto;
        width: 220px;
        background-color: #2c2c2c;
        border-radius: 15px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        padding: 15px;
        color: white;
        text-align: center;
        position: relative;
    }

        .event-card img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 50%;
            border: 3px solid white;
            margin-bottom: 10px;
        }

        .event-card h5 {
            font-size: 1.2rem;
            margin-bottom: 5px;
            font-weight: bold;
        }

        .event-card p {
            font-size: 0.9rem;
            color: #bbb;
            margin-bottom: 10px;
        }

        .event-card .btn-view {
            background-color: #ff4d4d;
            border: none;
            padding: 5px 12px;
            border-radius: 8px;
            color: white;
            font-size: 0.85rem;
            cursor: pointer;
            transition: background 0.3s;
        }

        .event-card .btn-view:hover {
            background-color: #e63e3e;
        }

</style>

<div class="container mt-5">
    <h2 class="mb-4">Event Details</h2>
    <button class="btn btn-primary float-end mb-3" data-bs-toggle="modal" data-bs-target="#eventModal">
        <i class="fas fa-plus"></i> Add Event
    </button>

    <div id="eventsContainer">
        <!-- Date-wise event sections will be rendered here -->
    </div>
</div>

<!-- Modal for adding event -->
<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content p-4">
            <h4 class="mb-4">Add New Event</h4>
            <form id="eventForm">
                <div class="row mb-3">
                    <div class="col">
                        <label>Event Name</label>
                        <input type="text" class="form-control" name="eventName" required />
                    </div>
                    <div class="col">
                        <label>Contact Number</label>
                        <input type="text" class="form-control" name="contactNumber" required />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col">
                        <label>Deadline Date</label>
                        <input type="date" class="form-control" name="deadlineDate" required />
                    </div>
                    <div class="col">
                        <label>Event Date</label>
                        <input type="date" class="form-control" name="eventDate" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label>Eligibility</label>
                    <textarea class="form-control" name="eligibility"></textarea>
                </div>
                <div class="mb-3">
                    <label>Description</label>
                    <textarea class="form-control" name="description"></textarea>
                </div>
                <div class="mb-3">
                    <label>Location</label>
                    <input type="text" class="form-control" name="location" />
                </div>
                <div class="mb-3">
                    <label>Division</label>
                    <select class="form-select" name="division">
                        <option value="Intra">Intra</option>
                        <option value="Inter">Inter</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label>Brochure Image</label>
                    <input type="file" class="form-control" name="brochureFile" accept="image/*" />
                </div>
                <button type="submit" class="btn btn-success">Save</button>
            </form>
        </div>
    </div>
</div>

<!-- Modal for full event details -->
<div class="modal fade" id="eventDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content p-4">
            <h4 id="eventDetailsTitle"></h4>
            <p><strong>Date:</strong> <span id="eventDetailsDate"></span></p>
            <p><strong>Deadline:</strong> <span id="eventDetailsDeadline"></span></p>
            <p><strong>Eligibility:</strong> <span id="eventDetailsEligibility"></span></p>
            <p><strong>Division:</strong> <span id="eventDetailsDivision"></span></p>
            <p><strong>Contact:</strong> <span id="eventDetailsContact"></span></p>
            <p><strong>Location:</strong> <span id="eventDetailsLocation"></span></p>
            <p><strong>Description:</strong> <span id="eventDetailsDescription"></span></p>
            <div id="eventDetailsBrochure"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            loadEvents();

            $('#eventForm').submit(function (e) {
                e.preventDefault();

                var formData = new FormData();
                formData.append("EventName", $('[name="eventName"]').val());
                formData.append("DeadlineDate", $('[name="deadlineDate"]').val());
                formData.append("EventDate", $('[name="eventDate"]').val());
                formData.append("Eligibility", $('[name="eligibility"]').val());
                formData.append("Division", $('[name="division"]').val());
                formData.append("ContactNumber", $('[name="contactNumber"]').val());
                formData.append("Description", $('[name="description"]').val());
                formData.append("Location", $('[name="location"]').val());
                var fileInput = $('[name="brochureFile"]')[0];
                if (fileInput.files.length > 0) {
                    formData.append("BrochureFile", fileInput.files[0]);
                }

                $.ajax({
                    url: '/EventDetails/SaveEvent',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        if (res.success) {
                            $('#eventModal').modal('hide');
                            $('#eventForm')[0].reset();
                            loadEvents();
                        } else {
                            alert(res.message || "Failed to save event.");
                        }
                    }
                });
            });

            function loadEvents() {
                $.get('/EventDetails/GetTodaysEvents', function (res) {
                    if (!res || !res.data) return;
                    let grouped = {};

                    res.data.forEach(e => {
                        let dateKey = e.eventDate ? e.eventDate.split('T')[0] : 'Unknown Date';
                        if (!grouped[dateKey]) grouped[dateKey] = [];
                        grouped[dateKey].push(e);
                    });

                    let html = '';
                    for (let date in grouped) {
                        html += `<div class="event-section">
                                    <h4>${date}</h4>
                                    <div class="event-slider">`;
                        // html += `<div class="event-card">
                        //             <h5>${ev.eventName}</h5>
                        //             <button class="btn btn-sm btn-primary" onclick='showDetails(${JSON.stringify(ev)})'>View Details</button>
                        //          </div>`;

                        grouped[date].forEach(ev => {
                            // html += `<div class="event-card">
                            //             <h5>${ev.eventName}</h5>
                            //             <button class="btn btn-sm btn-primary" onclick='showDetails(${JSON.stringify(ev)})'>View Details</button>
                            //          </div>`;
                            html += `<div class="event-card">
                                <img src="${ev.brochureUrl || 'https://via.placeholder.com/100'}" alt="${ev.eventName}">
                                <h5>${ev.eventName}</h5>
                                <p>${ev.location || ''}</p>
                                <button class="btn-view" onclick='showDetails(${JSON.stringify(ev)})'>View Details</button>
                             </div>`;
                        });
                        html += `</div></div>`;
                    }
                    $('#eventsContainer').html(html);
                });
            }

            window.showDetails = function (ev) {
                $('#eventDetailsTitle').text(ev.eventName);
                $('#eventDetailsDate').text(ev.eventDate ? ev.eventDate.split('T')[0] : '');
                $('#eventDetailsDeadline').text(ev.deadlineDate ? ev.deadlineDate.split('T')[0] : '');
                $('#eventDetailsEligibility').text(ev.eligibility || '');
                $('#eventDetailsDivision').text(ev.division || '');
                $('#eventDetailsContact').text(ev.contactNumber || '');
                $('#eventDetailsLocation').text(ev.location || '');
                $('#eventDetailsDescription').text(ev.description || '');
                $('#eventDetailsBrochure').html(ev.brochureUrl ? `<a href="${ev.brochureUrl}" target="_blank">📄 View Brochure</a>` : '');
                $('#eventDetailsModal').modal('show');
            }
        });
    </script>
}
