@model ksi.Models.FacultyDTO

@{
    ViewData["Title"] = "Faculty Details";
    Layout = "_Layout";
}

@{
    // Declare the faculties variable from ViewBag
    var faculties = ViewBag.Faculties as IEnumerable<ksi.Models.FacultyDTO>;
}

<style>
    .card {
        margin-bottom: 24px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .form-label {
        font-weight: 500;
    }

    .table th {
        font-weight: 600;
        white-space: nowrap;
    }

    .btn-action {
        padding: 4px 8px;
        font-size: 0.875rem;
    }

    .photo-preview {
        max-width: 200px;
        max-height: 200px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid #dee2e6;
    }

    .photo-upload-area {
        border: 2px dashed #dee2e6;
        border-radius: 8px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s;
    }

        .photo-upload-area:hover {
            border-color: #0d6efd;
            background-color: #f8f9fa;
        }

    .faculty-photo-small {
        width: 40px;
        height: 40px;
        object-fit: cover;
        border-radius: 50%;
    }
</style>

<div class="container-fluid mt-4">
    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bx bx-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bx bx-error me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model != null && Model.FacultyID >= 0 && ViewContext.RouteData.Values["id"] != null)
    {
        <!-- Faculty Form Card -->
        <div class="row mb-4" id="facultyFormWrapper">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">
                            <i class="bx bx-user-plus me-2"></i>@(Model.FacultyID > 0 ? "Edit Faculty" : "Add New Faculty")
                        </h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="SaveFaculty" method="post" id="facultyForm" enctype="multipart/form-data">
                            <input type="hidden" asp-for="FacultyID" />
                            <input type="hidden" asp-for="PhotoPath" />

                            <!-- Nav tabs -->
                            <ul class="nav nav-tabs" id="facultyTabs" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="basic-tab" data-bs-toggle="tab"
                                            data-bs-target="#basic" type="button" role="tab">
                                        <i class="bx bx-user me-1"></i>Basic Information
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="contact-tab" data-bs-toggle="tab"
                                            data-bs-target="#contact" type="button" role="tab">
                                        <i class="bx bx-phone me-1"></i>Contact Details
                                    </button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="additional-tab" data-bs-toggle="tab"
                                            data-bs-target="#additional" type="button" role="tab">
                                        <i class="bx bx-info-circle me-1"></i>Additional Info
                                    </button>
                                </li>
                            </ul>

                            <!-- Tab panes -->
                            <div class="tab-content mt-3" id="facultyTabContent">
                                <!-- Basic Information Tab -->
                                <div class="tab-pane fade show active" id="basic" role="tabpanel">
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label asp-for="FacultyName" class="form-label">
                                                Faculty Name <span class="text-danger">*</span>
                                            </label>
                                            <input asp-for="FacultyName" class="form-control"
                                                   placeholder="Enter faculty name" required />
                                            <span asp-validation-for="FacultyName" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label asp-for="Department" class="form-label">
                                                Department <span class="text-danger">*</span>
                                            </label>
                                            <select asp-for="Department" class="form-select" required>
                                                <option value="">-- Select Department --</option>
                                                <option value="Computer Science">Computer Science</option>
                                                <option value="Information Technology">Information Technology</option>
                                                <option value="AIDS">AIDS</option>
                                            </select>
                                            <span asp-validation-for="Department" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label asp-for="Designation" class="form-label">
                                                Designation <span class="text-danger">*</span>
                                            </label>
                                            <select asp-for="Designation" class="form-select" required>
                                                <option value="">-- Select Designation --</option>
                                                <option value="Professor">Professor</option>
                                                <option value="Associate Professor">Associate Professor</option>
                                                <option value="Assistant Professor">Assistant Professor</option>
                                                <option value="Lecturer">Lecturer</option>
                                                <option value="HOD">HOD</option>
                                            </select>
                                            <span asp-validation-for="Designation" class="text-danger"></span>
                                        </div>

                                        <div class="col-md-6 mb-3">
                                            <label asp-for="DOB" class="form-label">Date of Birth</label>
                                            <input asp-for="DOB" type="date" class="form-control" />
                                            <span asp-validation-for="DOB" class="text-danger"></span>
                                        </div>

                                        <div class="col-12 mb-3">
                                            <label asp-for="ExpertiseDomain" class="form-label">Expertise Domain</label>
                                            <textarea asp-for="ExpertiseDomain" class="form-control" rows="3"
                                                      placeholder="e.g., Machine Learning, Data Science, Web Development"></textarea>
                                            <span asp-validation-for="ExpertiseDomain" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Contact Details Tab -->
                                <div class="tab-pane fade" id="contact" role="tabpanel">
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label asp-for="CollegeMail" class="form-label">
                                                College Email <span class="text-danger">*</span>
                                            </label>
                                            <input asp-for="CollegeMail" type="email" class="form-control"
                                                   placeholder="faculty@college.edu" required />
                                            <span asp-validation-for="CollegeMail" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label asp-for="ContactNumber" class="form-label">Contact Number</label>
                                            <input asp-for="ContactNumber" type="tel" class="form-control"
                                                   placeholder="10-digit mobile number"
                                                   pattern="[0-9]{10}"
                                                   maxlength="10"
                                                   title="Please enter a valid 10-digit mobile number" />
                                            <span asp-validation-for="ContactNumber" class="text-danger"></span>
                                            <small class="text-muted">Enter 10-digit mobile number without country code</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Additional Info Tab -->
                                <div class="tab-pane fade" id="additional" role="tabpanel">
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <div class="form-check form-switch">
                                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                                                <label asp-for="IsActive" class="form-check-label">Active Status</label>
                                            </div>
                                        </div>

                                        <div class="col-12 mb-3">
                                            <label class="form-label">
                                                <i class="bx bx-image me-1"></i>Faculty Photo
                                            </label>

                                            @if (!string.IsNullOrEmpty(Model?.PhotoPath))
                                            {
                                                <div class="mb-3">
                                                    <img src="@Model.PhotoPath" alt="Current Photo" class="photo-preview" />
                                                    <div class="mt-2">
                                                        <small class="text-muted">Current photo - Upload a new one to replace</small>
                                                    </div>
                                                </div>
                                            }

                                            <div class="photo-upload-area" onclick="document.getElementById('photoInput').click()">
                                                <i class="bx bx-cloud-upload" style="font-size: 3rem; color: #6c757d;"></i>
                                                <p class="mb-1"><strong>Click to upload photo</strong></p>
                                                <p class="text-muted small mb-0">
                                                    Allowed: JPG, JPEG, PNG, GIF (Max 2MB)
                                                </p>
                                            </div>
                                            <input type="file"
                                                   id="photoInput"
                                                   name="photo"
                                                   accept="image/*"
                                                   class="d-none"
                                                   onchange="previewPhoto(this)" />
                                            <div id="photoPreview" class="mt-3"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="mt-4 border-top pt-3">
                                <button type="submit" class="btn btn-primary me-2">
                                    <i class="bx bx-save me-1"></i>
                                    @(Model.FacultyID > 0 ? "Update Faculty" : "Save Faculty")
                                </button>
                                <button type="button" class="btn btn-secondary" onclick="cancelForm()">
                                    <i class="bx bx-x me-1"></i>Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Faculty List Table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bx bx-list-ul me-2"></i>Faculty List
                    </h5>
                    <div>
                        @if (faculties != null)
                        {
                            <span class="badge bg-primary me-2">Total: @faculties.Count()</span>
                        }
                        <a asp-action="FacultyDetails" asp-route-id="0" class="btn btn-sm btn-success">
                            <i class="bx bx-plus me-1"></i>Add Faculty
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (faculties == null)
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bx bx-error-circle me-2"></i>
                            Unable to load faculty data. Please refresh the page.
                        </div>
                    }
                    else if (!faculties.Any())
                    {
                        <div class="text-center py-5">
                            <i class="bx bx-user-x" style="font-size: 4rem; color: #ccc;"></i>
                            <h5 class="mt-3 text-muted">No Faculty Records Found</h5>
                            <p class="text-muted">Add your first faculty member using the button above!</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-striped align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 60px;">Photo</th>
                                        <th style="width: 60px;">ID</th>
                                        <th>Name</th>
                                        <th>Department</th>
                                        <th>Designation</th>
                                        <th>Email</th>
                                        <th>Contact</th>
                                        <th style="width: 100px;">Status</th>
                                        <th style="width: 140px;" class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var faculty in faculties)
                                    {
                                        <tr>
                                            <td>
                                                @if (!string.IsNullOrEmpty(faculty.PhotoPath))
                                                {
                                                    <img src="@faculty.PhotoPath" alt="@faculty.FacultyName" class="faculty-photo-small" />
                                                }
                                                else
                                                {
                                                    <div class="faculty-photo-small bg-secondary d-flex align-items-center justify-content-center text-white">
                                                        <i class="bx bx-user"></i>
                                                    </div>
                                                }
                                            </td>
                                            <td>@faculty.FacultyID</td>
                                            <td>
                                                <strong>@faculty.FacultyName</strong>
                                            </td>
                                            <td>@faculty.Department</td>
                                            <td>
                                                <span class="badge bg-label-info">@faculty.Designation</span>
                                            </td>
                                            <td>
                                                <small>@faculty.CollegeMail</small>
                                            </td>
                                            <td>
                                                <small>@faculty.ContactNumber</small>
                                            </td>
                                            <td>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input"
                                                           type="checkbox"
                                                           @(faculty.IsActive ? "checked" : "")
                                                           onclick="toggleStatus(@faculty.FacultyID, this)"
                                                           style="cursor: pointer; width: 50px; height: 24px;">
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a asp-action="FacultyDetails"
                                                       asp-route-id="@faculty.FacultyID"
                                                       class="btn btn-sm btn-primary btn-action"
                                                       title="Edit Faculty">
                                                        <i class="bx bx-edit-alt"></i>
                                                    </a>
                                                    <button type="button"
                                                            class="btn btn-sm btn-danger btn-action"
                                                            onclick="confirmDelete(@faculty.FacultyID, '@faculty.FacultyName')"
                                                            title="Delete Faculty">
                                                        <i class="bx bx-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden delete form -->
<form id="deleteForm" method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // Preview photo before upload
        function previewPhoto(input) {
            var preview = document.getElementById('photoPreview');
            preview.innerHTML = '';

            if (input.files && input.files[0]) {
                var reader = new FileReader();
                var file = input.files[0];

                // Validate file size (2MB)
                if (file.size > 2 * 1024 * 1024) {
                    alert('File size must not exceed 2MB');
                    input.value = '';
                    return;
                }

                // Validate file type
                var validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
                if (!validTypes.includes(file.type)) {
                    alert('Only image files (JPG, JPEG, PNG, GIF) are allowed');
                    input.value = '';
                    return;
                }

                reader.onload = function (e) {
                    var img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'photo-preview';

                    var fileName = document.createElement('p');
                    fileName.className = 'mt-2 mb-0 text-muted small';
                    fileName.innerHTML = '<i class="bx bx-check-circle text-success me-1"></i>Selected: ' + file.name;

                    preview.appendChild(img);
                    preview.appendChild(fileName);
                };

                reader.readAsDataURL(file);
            }
        }

                function cancelForm() {
            document.getElementById('facultyFormWrapper').style.display = 'none';
            // Scroll back to the table smoothly
            $('html, body').animate({
                scrollTop: $('.card:last').offset().top - 100   
            }, 400);
        }

        function toggleStatus(facultyId, checkbox) {
            $.ajax({
                url: '@Url.Action("ToggleFacultyStatus", "Faculty")',
                type: 'POST',
                data: {
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                    facultyId: facultyId
                },
                success: function(result) {
                    if (!result.success) {
                        alert('Error: ' + result.message);
                        checkbox.checked = !checkbox.checked; // Revert
                    }
                },
                error: function() {
                    alert('Error updating status');
                    checkbox.checked = !checkbox.checked; // Revert
                }
            });
        }

        // Clear photo preview on reset
        function clearPhotoPreview() {
            document.getElementById('photoInput').value = '';
            document.getElementById('photoPreview').innerHTML = '';
        }

        $(document).ready(function () {
            // Auto-dismiss alerts after 5 seconds
            setTimeout(function () {
                $('.alert').fadeOut('slow');
            }, 5000);

            // Scroll to form if editing
            @if (Model?.FacultyID >= 0 && ViewContext.RouteData.Values["id"] != null)
            {
                <text>
                $('html, body').animate({
                    scrollTop: $('#facultyForm').offset().top - 100
                }, 500);
                </text>
            }
            else
            {
                <text>
                // Scroll to table after adding new faculty
                if ($('.alert-success').length > 0) {
                    setTimeout(function() {
                        $('html, body').animate({
                            scrollTop: $('.card:last').offset().top - 100
                        }, 500);
                    }, 100);
                }
                </text>
            }
        });

        // Delete confirmation
        function confirmDelete(facultyId, facultyName) {
            if (confirm(`Are you sure you want to delete faculty "${facultyName}"?\n\nThis action cannot be undone.`)) {
                var form = document.getElementById('deleteForm');
                form.action = '@Url.Action("Delete", "Faculty")/' + facultyId;
                form.submit();
            }
        }
    </script>
}
