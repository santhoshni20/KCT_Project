@using KSI_Project.Models.DTOs
@model AddFacultyDto

<div class="container mt-4">
    <h3 class="mb-4">Add Faculty</h3>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <!-- ✅ enctype is required for file upload -->
    <form asp-action="Add" method="post" enctype="multipart/form-data" id="facultyForm" novalidate>
        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="FacultyName" class="form-label"></label>
                <input asp-for="FacultyName" class="form-control" />
                <span asp-validation-for="FacultyName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Department" class="form-label"></label>
                <!-- ✅ readonly visible + hidden real input -->
                <input type="text" class="form-control" value="@Model.Department" readonly />
                <input type="hidden" name="Department" value="@Model.Department" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="CollegeMail" class="form-label"></label>
                <input asp-for="CollegeMail" class="form-control" />
                <span asp-validation-for="CollegeMail" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ContactNumber" class="form-label"></label>
                <input asp-for="ContactNumber" class="form-control" />
                <span asp-validation-for="ContactNumber" class="text-danger"></span>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="DOB" class="form-label"></label>
                <input asp-for="DOB" type="date" class="form-control" />
                <span asp-validation-for="DOB" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ExpertiseDomain" class="form-label"></label>
                <input asp-for="ExpertiseDomain" class="form-control" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label for="PhotoFile" class="form-label">Faculty Photo</label>
                <!-- ✅ must match controller parameter name -->
                <input type="file" name="PhotoFile" id="PhotoFile" class="form-control" accept="image/*" />
            </div>
            <div class="col-md-6 text-center">
                <img id="photoPreview" src="#" alt="Preview" class="img-thumbnail d-none"
                     style="width:150px;height:150px;object-fit:cover;" />
            </div>
        </div>

        <div class="text-end">
            <a href="@Url.Action("Index", "FacultySupport")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <button type="submit" id="saveBtn" class="btn btn-primary">
                <i class="bi bi-save"></i> Save
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            'use strict';
            const form = document.getElementById('facultyForm');
            const saveBtn = document.getElementById('saveBtn');
            const photoInput = document.getElementById('PhotoFile');
            const preview = document.getElementById('photoPreview');

            form.addEventListener('submit', (e) => {
                if (!form.checkValidity()) {
                    e.preventDefault();
                    return false;
                }
                saveBtn.disabled = true;
                saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
            });

            window.addEventListener('pageshow', () => {
                saveBtn.disabled = false;
                saveBtn.innerHTML = '<i class="bi bi-save"></i> Save';
            });

            photoInput.addEventListener('change', (e) => {
                const file = e.target.files[0];
                if (!file) {
                    preview.classList.add('d-none');
                    return;
                }
                const valid = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif'];
                if (!valid.includes(file.type)) {
                    alert('Only JPG, PNG, GIF allowed.');
                    e.target.value = '';
                    preview.classList.add('d-none');
                    return;
                }
                if (file.size > 5 * 1024 * 1024) {
                    alert('Max 5MB file allowed.');
                    e.target.value = '';
                    preview.classList.add('d-none');
                    return;
                }
                const reader = new FileReader();
                reader.onload = (ev) => {
                    preview.src = ev.target.result;
                    preview.classList.remove('d-none');
                };
                reader.readAsDataURL(file);
            });
        })();
    </script>
}
