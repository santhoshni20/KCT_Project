@model IEnumerable<KSI_Project.Models.DTOs.FacultyDto>
@{
    var dept = ViewBag.Department as string;
    ViewData["Title"] = $"{dept} Faculty";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-users"></i> @dept Department Faculty
        </h2>
        <div>
            <a href="@Url.Action("Add", new { dept = dept })" class="btn btn-success">
                <i class="fas fa-plus"></i> Add Faculty
            </a>
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var f in Model)
            {
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="card h-100 shadow-sm faculty-card">
                        <div class="card-body text-center">
                            <img src="@f.PhotoPath"
                                 alt="@f.FacultyName"
                                 class="rounded-circle mb-3"
                                 style="width: 100px; height: 100px; object-fit: cover;"
                                 onerror="this.src='/images/faculty/default.jpg'" />
                            <h5 class="card-title mb-1">@f.FacultyName</h5>
                            <p class="text-muted small mb-2">@(string.IsNullOrEmpty(f.Designation) ? "Faculty" : f.Designation)</p>

                            @if (!string.IsNullOrEmpty(f.ExpertiseDomain))
                            {
                                <p class="text-muted small mb-3">
                                    <i class="fas fa-lightbulb"></i> @f.ExpertiseDomain
                                </p>
                            }

                            <div class="d-flex gap-2 justify-content-center">
                                <a href="@Url.Action("Details", new { id = f.FacultyID })"
                                   class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="@Url.Action("Edit", new { id = f.FacultyID })"
                                   class="btn btn-sm btn-primary">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-danger"
                                        onclick="confirmDelete(@f.FacultyID, '@f.FacultyName')">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> No faculty members found in this department.
                    <br />
                    <a href="@Url.Action("Add", new { dept = dept })" class="btn btn-success mt-3">
                        <i class="fas fa-plus"></i> Add First Faculty Member
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle"></i> Confirm Delete
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="facultyNameToDelete"></strong>?</p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .faculty-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border-radius: 12px;
    }

        .faculty-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2) !important;
        }

    .d-flex.gap-2 {
        gap: 0.5rem;
    }

    .btn-sm {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
    }
</style>

@section Scripts {
    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);

        let facultyIdToDelete = 0;

        function confirmDelete(id, name) {
            facultyIdToDelete = id;
            $('#facultyNameToDelete').text(name);
            $('#deleteForm').attr('action', '/FacultySupport/Delete/' + id);
            $('#deleteModal').modal('show');
        }

        // Handle delete form submission
        $('#deleteForm').on('submit', function(e) {
            e.preventDefault();

            const form = $(this);
            const actionUrl = form.attr('action');
            const formData = form.serialize();

            $.ajax({
                url: actionUrl,
                type: 'POST',
                data: formData,
                success: function(response) {
                    $('#deleteModal').modal('hide');
                    location.reload();
                },
                error: function() {
                    alert('Failed to delete faculty member. Please try again.');
                }
            });
        });
    </script>
}