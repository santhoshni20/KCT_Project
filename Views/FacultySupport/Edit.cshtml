@using KSI_Project.Models.DTOs
@model AddFacultyDto

<div class="container mt-4">
    <h3 class="mb-4">Edit Faculty</h3>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="facultyForm" novalidate>
        <input type="hidden" asp-for="FacultyID" />
        <input type="hidden" asp-for="Department" />
        <input type="hidden" asp-for="PhotoPath" id="hiddenPhotoPath" />

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="FacultyName" class="form-label"></label>
                <input asp-for="FacultyName" class="form-control" />
                <span asp-validation-for="FacultyName" class="text-danger"></span>
            </div>
            @* <div class="col-md-6">
               //<label asp-for="Designation" class="form-label"></label>
               // <input asp-for="Designation" class="form-control" />
            </div> *@
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="CollegeMail" class="form-label"></label>
                <input asp-for="CollegeMail" class="form-control" />
                <span asp-validation-for="CollegeMail" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ContactNumber" class="form-label"></label>
                <input asp-for="ContactNumber" class="form-control" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label asp-for="DOB" class="form-label"></label>
                <input asp-for="DOB" type="date" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="ExpertiseDomain" class="form-label"></label>
                <input asp-for="ExpertiseDomain" class="form-control" />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6">
                <label for="PhotoFile" class="form-label">Faculty Photo</label>
                <input type="file" name="PhotoFile" id="PhotoFile" class="form-control" accept="image/*" />
                <small class="text-muted">Leave empty to keep current photo</small>
            </div>
            <div class="col-md-6 text-center">
                <div id="imageContainer">
                    <img id="currentPhoto" src="@Model.PhotoPath" alt="Current Photo"
                         class="img-thumbnail" style="width:150px;height:150px;object-fit:cover;"
                         onerror="this.src='/images/faculty/default.jpg'" />
                    <img id="photoPreview" src="#" alt="Preview"
                         class="img-thumbnail d-none mt-2" style="width:150px;height:150px;object-fit:cover;" />
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-12 text-end">
                <a href="@Url.Action("Index", "FacultySupport")" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
                <button type="submit" id="saveBtn" class="btn btn-success">
                    <i class="bi bi-save"></i> Save Changes
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function() {
            'use strict';

            var isSubmitting = false;
            var form = document.getElementById('facultyForm');
            var saveBtn = document.getElementById('saveBtn');
            var photoInput = document.getElementById('PhotoFile');
            var preview = document.getElementById('photoPreview');
            var currentPhoto = document.getElementById('currentPhoto');

            function onFormSubmit(e) {
                if (isSubmitting) {
                    e.preventDefault();
                    return false;
                }

                if (!form.checkValidity()) {
                    e.preventDefault();
                    return false;
                }

                isSubmitting = true;
                if (saveBtn) {
                    saveBtn.disabled = true;
                    saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
                }
            }

            function onPageShow(event) {
                isSubmitting = false;
                if (saveBtn) {
                    saveBtn.disabled = false;
                    saveBtn.innerHTML = '<i class="bi bi-save"></i> Save Changes';
                }
            }

            function onPhotoChange(e) {
                var file = e.target.files[0];

                if (!file) {
                    preview.classList.add('d-none');
                    if (currentPhoto) {
                        currentPhoto.style.opacity = '1';
                    }
                    return;
                }

                var validTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif'];
                if (validTypes.indexOf(file.type) === -1) {
                    alert('Invalid file type. Allowed: JPG, PNG, GIF.');
                    e.target.value = '';
                    preview.classList.add('d-none');
                    if (currentPhoto) {
                        currentPhoto.style.opacity = '1';
                    }
                    return;
                }

                if (file.size > 5 * 1024 * 1024) {
                    alert('File too large (max 5MB).');
                    e.target.value = '';
                    preview.classList.add('d-none');
                    if (currentPhoto) {
                        currentPhoto.style.opacity = '1';
                    }
                    return;
                }

                var reader = new FileReader();
                reader.onload = function(ev) {
                    preview.src = ev.target.result;
                    preview.classList.remove('d-none');
                    if (currentPhoto) {
                        currentPhoto.style.opacity = '0.4';
                    }
                };
                reader.readAsDataURL(file);
            }

            if (form) {
                form.addEventListener('submit', onFormSubmit);
            }

            window.addEventListener('pageshow', onPageShow);

            if (photoInput) {
                photoInput.addEventListener('change', onPhotoChange);
            }

        })();
    </script>
}