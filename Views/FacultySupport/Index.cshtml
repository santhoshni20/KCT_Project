@{
    ViewData["Title"] = "Faculty Support";
}
<div class="container-fluid py-4">
    <h2 class="mb-4 text-center">🎓 Faculty Support System</h2>

    <!-- Department Selection Section -->
    <div class="row text-center mb-5">
        <div class="col-md-4 mb-3">
            <div class="card dept-card shadow-sm" data-dept="CSE">
                <div class="card-body p-4">
                    <i class="fas fa-laptop-code fa-3x mb-3 text-primary"></i>
                    <h4 class="card-title">CSE</h4>
                    <p class="text-muted">Computer Science</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card dept-card shadow-sm" data-dept="IT">
                <div class="card-body p-4">
                    <i class="fas fa-network-wired fa-3x mb-3 text-success"></i>
                    <h4 class="card-title">IT</h4>
                    <p class="text-muted">Information Technology</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card dept-card shadow-sm" data-dept="AIDS">
                <div class="card-body p-4">
                    <i class="fas fa-brain fa-3x mb-3 text-danger"></i>
                    <h4 class="card-title">AIDS</h4>
                    <p class="text-muted">AI & Data Science</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="row mb-4" id="filterSection" style="display:none;">
        <div class="col-md-6">
            <input type="text" id="searchBox" class="form-control" placeholder="🔍 Search faculty by name...">
        </div>
        <div class="col-md-4">
            <select id="domainFilter" class="form-control">
                <option value="">Filter by Domain</option>
                <option value="Artificial Intelligence">Artificial Intelligence</option>
                <option value="Machine Learning">Machine Learning</option>
                <option value="Data Science">Data Science</option>
                <option value="Web Development">Web Development</option>
                <option value="Cloud Computing">Cloud Computing</option>
                <option value="IoT">IoT</option>
                <option value="Cybersecurity">Cybersecurity</option>
            </select>
        </div>
        <div class="col-md-2">
            <a id="addDeptBtn" class="btn btn-success w-100" style="display:none;">+ Add Faculty</a>
        </div>
    </div>

    <!-- Faculty List Display Section -->
    <div id="facultyList" class="row"></div>
</div>

<!-- Faculty Detail Modal (same as you had) -->
<div class="modal fade" id="facultyModal" tabindex="-1" aria-hidden="true">
    <!-- modal inner (unchanged) -->
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="facultyName"></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row">
                    <div class="col-md-4 text-center">
                        <img id="facultyPhoto" src="/images/faculty/default.jpg" alt="Faculty Photo"
                             class="img-fluid rounded-circle mb-3 shadow" style="height:150px;width:150px;object-fit:cover;">
                    </div>
                    <div class="col-md-8">
                        <table class="table table-borderless">
                            <tr><td><strong>📅 DOB:</strong></td><td><span id="facultyDob"></span></td></tr>
                            <tr><td><strong>🏫 Department:</strong></td><td><span id="facultyDept"></span></td></tr>
                            <tr><td><strong>🎓 Designation:</strong></td><td><span id="facultyDesignation"></span></td></tr>
                            <tr><td><strong>📚 Domain:</strong></td><td><span id="facultyDomain" class="badge bg-info"></span></td></tr>
                            <tr><td><strong>📧 Email:</strong></td><td><a href="#" id="facultyEmail"></a></td></tr>
                            <tr><td><strong>☎️ Phone:</strong></td><td><span id="facultyPhone"></span></td></tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* same styles as you had */
    .dept-card {
        cursor: pointer;
        border: 2px solid #e0e0e0;
        transition: all .3s;
        border-radius: 15px;
        height: 100%;
    }

        .dept-card:hover {
            background: linear-gradient(135deg,#667eea 0%,#764ba2 100%);
            color: white;
            transform: translateY(-10px);
            box-shadow: 0 10px 20px rgba(0,0,0,.2);
        }

    .faculty-card {
        border-radius: 15px;
        box-shadow: 0 4px 8px rgba(0,0,0,.1);
        cursor: pointer;
        transition: all .3s;
        height: 100%;
    }

        .faculty-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,.2);
        }

    .domain-badge {
        display: inline-block;
        padding: 5px 10px;
        margin: 2px;
        border-radius: 20px;
        font-size: .85em;
        background: #f0f0f0;
        color: #333;
    }
</style>

@section Scripts {
    <script>
        let allFaculties = [];
        let currentDepartment = '';

        $('.dept-card').click(function () {
            const dept = $(this).data('dept');
            currentDepartment = dept;
            $('#filterSection').show();
            $('#addDeptBtn').show().attr('href', '/FacultySupport/Add?dept=' + dept);
            loadFacultyByDepartment(dept);
        });

        function loadFacultyByDepartment(department) {
            $.ajax({
                url: '/FacultySupport/GetFacultyByDepartment',
                type: 'GET',
                data: { department: department },
                success: function (response) {
                    if (response.success) {
                        allFaculties = response.data;
                        displayFaculties(allFaculties);
                    } else {
                        $('#facultyList').html('<div class="col-12 text-center"><p class="text-muted">'+response.message+'</p></div>');
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Error:', error);
                    alert('Failed to load faculty data');
                }
            });
        }

        function displayFaculties(faculties) {
            if (!faculties || faculties.length === 0) {
                $('#facultyList').html('<div class="col-12 text-center"><p class="text-muted">No faculty found in this department.</p></div>');
                return;
            }
            let html = '';
            faculties.forEach(f => {
                const domains = f.ExpertiseDomain ? f.ExpertiseDomain.split(',') : [];
                const domainTags = domains.map(d => `<span class="domain-badge">${d.trim()}</span>`).join(' ');
                html += `
                    <div class="col-md-3 col-sm-6 mb-4">
                      <div class="card faculty-card p-3" data-id="${f.FacultyID}">
                        <img src="${f.PhotoPath || '/images/faculty/default.jpg'}" class="rounded-circle mb-3 mx-auto d-block" style="height:100px;width:100px;object-fit:cover;" onerror="this.src='/images/faculty/default.jpg'">
                        <h6 class="text-center mb-1">${f.FacultyName}</h6>
                        <p class="text-center text-muted small mb-2">${f.Designation || 'Faculty'}</p>
                        <div class="text-center mb-2">${domainTags}</div>
                        <small class="text-center text-muted"><i class="fas fa-envelope"></i> ${f.CollegeMail || 'N/A'}</small>
                      </div>
                    </div>`;
            });
            $('#facultyList').html(html);
        }

        $(document).on('click', '.faculty-card', function () {
            const id = $(this).data('id');
            $.ajax({
                url: '/FacultySupport/GetFacultyById',
                type: 'GET',
                data: { id: id },
                success: function (response) {
                    if (response.success) {
                        const f = response.data;
                        $('#facultyName').text(f.FacultyName);
                        $('#facultyPhoto').attr('src', f.PhotoPath || '/images/faculty/default.jpg');
                        $('#facultyDob').text(f.DOB ? new Date(f.DOB).toLocaleDateString() : 'N/A');
                        $('#facultyDept').text(f.Department);
                        $('#facultyDesignation').text(f.Designation || 'N/A');
                        $('#facultyDomain').text(f.ExpertiseDomain || 'N/A');
                        $('#facultyEmail').text(f.CollegeMail || 'N/A').attr('href','mailto:' + (f.CollegeMail || ''));
                        $('#facultyPhone').text(f.ContactNumber || 'N/A');
                        $('#facultyModal').modal('show');
                    } else {
                        alert(response.message);
                    }
                }
            });
        });

        $('#searchBox').on('keyup', function () {
            const q = $(this).val().toLowerCase();
            const filtered = allFaculties.filter(f => f.FacultyName && f.FacultyName.toLowerCase().includes(q));
            displayFaculties(filtered);
        });

        $('#domainFilter').on('change', function () {
            const d = $(this).val();
            if (!d) displayFaculties(allFaculties);
            else displayFaculties(allFaculties.filter(f => f.ExpertiseDomain && f.ExpertiseDomain.includes(d)));
        });

        $('#backBtn').click(function () {
            $('#facultyList').html('');
            $('#filterSection').hide();
            $('#addDeptBtn').hide();
            $('#searchBox').val('');
            $('#domainFilter').val('');
            currentDepartment = '';
        });
    </script>
}
