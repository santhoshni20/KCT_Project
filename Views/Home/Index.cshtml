@{
    ViewData["Title"] = "Home Page";
}

<style>
    .page-wrapper {
        text-align: center;
        margin-top: 100px;
    }

    .page-wrapper h1 {
        font-size: 48px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .page-wrapper p {
        font-size: 18px;
        color: #333;
    }

    .event-button {
        background-color: #007bff;
        color: white;
        padding: 12px 28px;
        font-size: 18px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        text-decoration: none;
        margin-top: 30px;
        display: inline-block;
        transition: background-color 0.3s ease;
    }

    .event-button:hover {
        background-color: #0056b3;
    }
</style>

<div class="page-wrapper">
    <h1>Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>

    <br />

</div>
