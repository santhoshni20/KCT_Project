@{
    ViewData["Title"] = "Home Page";
}

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        font-family: Arial, sans-serif;
        overflow: hidden; /* Prevent all scrolling */
    }

    .background {
        background-image: url('/images/your-image.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        position: fixed;
        top: 0;
        left: 240px; /* Respect the sidebar width */
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        box-sizing: border-box;
    }

    .content {
        text-align: center;
        background-color: rgba(0, 0, 0, 0.6);
        color: white;
        padding: 40px;
        border-radius: 12px;
        max-width: 900px;
        width: 100%;
    }
</style>

<div class="background">
    <div class="content">
        <h1>Welcome</h1>
        <p>
            Innovation from <strong>Kumaraguru School of Innovation (KSI)</strong>,
            a part of Kumaraguru Institutions. KSI is powered by
            <strong>Forge Accelerator</strong>, India’s pioneering hardware incubator.
        </p>
    </div>
</div>
