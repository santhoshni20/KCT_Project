@{
    ViewData["Title"] = "Home Page";
}

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        font-family: Arial, sans-serif;
        overflow: hidden; /* Prevent all scrolling */
    }

    .background {
        background-image: url('/images/ff134a71-db8d-405e-a883-a69138619dd3.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        position: fixed;
        top: 0;
        left: 240px; /* Respect the sidebar width */
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        box-sizing: border-box;
    }

    .content {
        text-align: center;
        background-color: rgba(0, 0, 0, 0.6);
        color: white;
        padding: 40px;
        border-radius: 12px;
        max-width: 900px;
        width: 100%;
    }

    .profile-round-btn {
        position: absolute;
        top: 15px;
        right: 20px;
        width: 44px;
        height: 44px;
        background: #007bff;
        border-radius: 50%;
        border: none;
        box-shadow: 0 2px 6px rgba(0,0,0,0.12);
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        z-index: 1000;
    }

        .profile-round-btn:hover {
            background: #0056b3;
        }

        .profile-round-btn::before {
            content: '';
            display: block;
            width: 16px;
            height: 16px;
            background: white;
            border-radius: 50%;
        }
</style>

<a href="/Profile" class="profile-round-btn" title="Go to Profile"></a>

<div class="background">
    <div class="content">
        <h1>Welcome</h1>
        <p>
            Innovation from <strong>Kumaraguru School of Innovation (KSI)</strong>,
            a part of Kumaraguru Institutions. KSI is powered by
            <strong>Forge Accelerator</strong>, India’s pioneering hardware incubator.
        </p>
    </div>
</div>