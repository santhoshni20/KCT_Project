@{
    ViewData["Title"] = "Placement Support";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<style>
    body {
        background-color: #f8f9fa;
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
    }

    .placement-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        min-height: 100vh;
        padding-top: 50px;
    }

    .placement-card {
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        padding: 30px;
        width: 70%;
        max-width: 900px;
    }

    h2 {
        text-align: center;
        color: #333;
        margin-bottom: 25px;
        font-weight: 600;
    }

    label {
        font-weight: 500;
        color: #333;
    }

    .form-select {
        width: 100%;
        max-width: 400px;
        margin: 0 auto;
        display: block;
    }

    table {
        width: 100%;
        margin-top: 25px;
        border-collapse: collapse;
    }

    th, td {
        border: 1px solid #ddd;
        text-align: center;
        padding: 10px;
    }

    th {
        background-color: #3b82f6;
        color: white;
    }

    tr:hover {
        background-color: #f1f1f1;
    }

    footer {
        position: fixed;
        bottom: 0;
        width: 100%;
        background: #f1f1f1;
        text-align: center;
        padding: 10px 0;
        border-top: 1px solid #ddd;
        font-size: 14px;
        color: #333;
    }
</style>

<div class="placement-container">
    <div class="placement-card">
        <h2>Placement Support</h2>

        <!-- Dropdown -->
        <div class="mb-3 text-center">
            <label for="domainSelect" class="form-label">Select Domain</label>
            <select id="domainSelect" class="form-select" required>
                <option value="">-- Choose Domain --</option>
                <option value="AI">Artificial Intelligence</option>
                <option value="ML">Machine Learning</option>
                <option value="WebDev">Web Development</option>
                <option value="DataScience">Data Science</option>
                <option value="CyberSecurity">Cyber Security</option>
            </select>
        </div>

        <!-- Data Table -->
        <div class="table-responsive">
            <table id="placementTable" class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Mobile Number</th>
                        <th>Email ID</th>
                        <th>Company Name</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="4" class="text-center text-muted">Select a domain to view details</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<footer>
    © 2025 - KSI_Project | Placement Support
</footer>

<script>
        // load domains
    $(document).ready(function () {
        $.get("/api/PlacementSupport/domains", function (res) {
            if (res && res.statusCode === 200 && Array.isArray(res.data)) {
                const domainSelect = $("#domainSelect");
                domainSelect.empty();
                domainSelect.append('<option value="">-- Choose Domain --</option>');
                res.data.forEach(d => {
                    domainSelect.append(`<option value="${d}">${d}</option>`);
                });
            }
        });

        // on domain change, fetch students
        $("#domainSelect").on("change", function () {
            const selected = $(this).val();
            const tbody = $("#placementTable tbody");
            tbody.empty();

            if (!selected) {
                tbody.append(`<tr><td colspan="4" class="text-center text-muted">Select a domain to view details</td></tr>`);
                return;
            }

            $.get("/api/PlacementSupport/students", { domain: selected }, function (res) {
                if (res && res.statusCode === 200 && Array.isArray(res.data) && res.data.length > 0) {
                    res.data.forEach(item => {
                        const row = `<tr>
                            <td>${escapeHtml(item.name)}</td>
                            <td>${escapeHtml(item.contactNumber)}</td>
                            <td>${escapeHtml(item.email ?? "")}</td>
                            <td>${escapeHtml(item.companyName ?? "")}</td>
                        </tr>`;
                        tbody.append(row);
                    });
                } else {
                    tbody.append(`<tr><td colspan="4" class="text-center text-muted">No data available for the selected domain</td></tr>`);
                }
            }).fail(function () {
                tbody.append(`<tr><td colspan="4" class="text-center text-danger">Error loading data</td></tr>`);
            });
        });
    });

    // small helper to avoid XSS when rendering server data in DOM
    function escapeHtml(text) {
        if (!text) return "";
        return $('<div/>').text(text).html();
    }

</script>
