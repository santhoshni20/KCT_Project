
@{
    ViewData["Title"] = "User Details Form";
}


<style>
    /* General body styling */
    body {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        margin: 0;
        font-family: Arial, sans-serif;
        background-color: #f8f9fa;
    }

    /* Sidebar (KSI Services menu) */
    .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        width: 220px;
        height: 100%;
        background-color: #1f2937; /* dark theme */
        color: #fff;
        padding-top: 20px;
    }

        .sidebar a {
            display: block;
            color: #3b82f6; /* bootstrap blue */
            padding: 10px 15px;
            text-decoration: none;
            font-size: 15px;
        }

            .sidebar a:hover {
                background-color: #374151;
                border-radius: 6px;
            }

    /* Main content area */
    .container {
        margin-left: 240px; /* space for sidebar */
        padding: 20px;
        flex: 1;
        padding-bottom: 100px; /* Prevent footer overlap */
    }

    /* Card-like style for user details */
    .user-details {
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        padding: 20px;
    }

    /* Footer styling */
    footer {
        position: fixed;
        bottom: 0;
        width: 100%;
        background: #f1f1f1;
        text-align: center;
        padding: 10px 0;
        border-top: 1px solid #ddd;
        font-size: 14px;
        z-index: 1000;
    }

    /* Adjust content to not hide behind footer */
    body {
        margin-bottom: 60px; /* height of footer */
    }
</style>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">
    <h2 class="mb-4">User Details Form</h2>

    <!-- Step 1: Enter Roll Number -->
    <form method="post" asp-action="GetDetails">
        <div class="mb-3">
            <label for="RollNo" class="form-label">Roll No</label>
            <input type="text" class="form-control" id="RollNo" name="RollNo" placeholder="Enter Roll No" required />
        </div>
        <button type="submit" class="btn btn-primary">Get Details</button>
    </form>

    <!-- Display message if no record found -->
    @if (ViewBag.Message != null)
    {
        <div class="alert alert-danger mt-3">@ViewBag.Message</div>
    }

    @if (Model != null)
    {
        <h4 class="mt-4">Details:</h4>
        <hr />

        <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" class="form-control" value="@Model.Name" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Designation</label>
            <input type="text" class="form-control" value="@Model.Designation" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Company</label>
            <input type="text" class="form-control" value="@Model.Company" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Package</label>
            <input type="text" class="form-control" value="@Model.Package" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Expertise</label>
            <input type="text" class="form-control" value="@Model.Expertise" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Contact</label>
            <input type="text" class="form-control" value="@Model.Contact" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Personal Mail ID</label>
            <input type="text" class="form-control" value="@Model.Email" readonly />
        </div>
    }
</div>
