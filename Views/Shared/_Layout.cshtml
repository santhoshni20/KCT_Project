@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KCT_Project</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KCT_Project.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            display: flex;
            min-height: 100vh;
            margin: 0;
        }

        .sidebar {
            width: 240px;
            background-color: #343a40;
            color: white;
            position: fixed;
            top: 0;
            bottom: 0;
            padding-top: 60px;
        }

        .sidebar .nav-link {
            color: #ccc;
            padding: 12px 20px;
            display: block;
        }

        .sidebar .nav-link:hover {
            background-color: #495057;
            color: white;
            text-decoration: none;
        }

        .main-content {
            margin-left: 240px;
            padding: 20px;
            flex-grow: 1;
            background-color: #f8f9fa;
        }

        header {
            position: fixed;
            top: 0;
            left: 240px;
            right: 0;
            z-index: 1000;
        }

        .footer {
            margin-left: 240px;
            padding: 1rem;
            background-color: #e9ecef;
            text-align: center;
        }
    </style>
</head>
<body>
    <!-- Left Sidebar -->
    <nav class="sidebar">
        <div class="sidebar-sticky">
            <h5 class="text-center text-light">KCT Services</h5>
            <ul class="nav flex-column mt-4">
                <li><a class="nav-link" asp-controller="CGPA" asp-action="Index"><i class="fas fa-calculator"></i> CGPA Calculation</a></li>
                <li><a class="nav-link" asp-controller="Placement" asp-action="Support"><i class="fas fa-briefcase"></i> Placement Support</a></li>
                <li><a class="nav-link" asp-controller="Calendar" asp-action="Academic"><i class="fas fa-calendar-alt"></i> Academic Calendar</a></li>
                <li><a class="nav-link" asp-controller="Events" asp-action="Daily"><i class="fas fa-bullhorn"></i> Daily Events</a></li>
                <li><a class="nav-link" asp-controller="Canteen" asp-action="Details"><i class="fas fa-utensils"></i> Canteen Details</a></li>
                <li><a class="nav-link" asp-controller="Faculty" asp-action="Support"><i class="fas fa-users"></i> Faculty Support</a></li>
                <li><a class="nav-link" asp-controller="Timetable" asp-action="Index"><i class="fas fa-table"></i> Timetable</a></li>
                <li><a class="nav-link" asp-controller="IDBalance" asp-action="Index"><i class="fas fa-id-card"></i> ID Balance</a></li>
            </ul>
        </div>
    </nav>

    <!-- Header -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">KCT_Project</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <div class="main-content pt-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="footer">
        &copy; 2025 - KCT_Project - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
