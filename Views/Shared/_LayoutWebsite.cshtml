@{
    Layout = null;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] | BINI</title>
    <link rel="icon" type="image/x-icon" href="~/img/favicon/bini_web_tab_logo.ico" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --bg-main: #000;
            --bg-elevated: #111;
            --text-main: #fff;
            --text-muted: #aaa;
            --border-subtle: rgba(255,255,255,0.1);
        }

        body {
            margin: 0;
            background: var(--bg-main);
            color: var(--text-main);
            font-family: Arial, sans-serif;
        }

        /* ================= HEADER ================= */
        .top-bar-shell {
            position: fixed;
            inset: 0 0 auto 0;
            z-index: 1000;
        }

        .top-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 24px;
            background: rgba(0,0,0,0.9);
            border-bottom: 1px solid var(--border-subtle);
        }

        .brand-block img {
            width: 35px;
        }

        .menu-btn {
            background: none;
            border: 1px solid rgba(255,255,255,0.4);
            width: 36px;
            height: 36px;
            border-radius: 6px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 5px;
            cursor: pointer;
        }

            .menu-btn span {
                height: 2px;
                background: white;
                width: 18px;
                margin: 0 auto;
            }

        /* ================= SIDEBAR ================= */
        .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            display: none;
            z-index: 999;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: -280px;
            width: 280px;
            height: 100%;
            background: #0d0d0d;
            padding: 30px 20px;
            transition: left 0.35s ease;
            z-index: 1000;
        }

            .sidebar.active {
                left: 0;
            }

        .sidebar-overlay.active {
            display: block;
        }

        .sidebar h4 {
            font-size: 0.8rem;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 24px;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .sidebar-menu li {
                margin-bottom: 14px;
            }

            .sidebar-menu a {
                color: var(--text-main);
                text-decoration: none;
                font-size: 0.95rem;
                display: block;
                padding: 10px 12px;
                border-radius: 6px;
                transition: background 0.25s;
            }

                .sidebar-menu a:hover {
                    background: rgba(255,255,255,0.1);
                }

        /* ================= CONTENT ================= */
        main.page-content {
            padding-top: 80px;
            min-height: 100vh;
        }
    </style>

    @RenderSection("PageStyles", required: false)
</head>

<body>

    <!-- HEADER -->
    <div class="top-bar-shell">
        <header class="top-bar">
            <div class="brand-block">
                <img src="~/img/favicon/bini_black_logo.ico" />
            </div>

            <!-- MENU ICON -->
            <button class="menu-btn" id="openMenu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </header>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <aside class="sidebar" id="sidebar">
        <h4>Student Services</h4>
        <ul class="sidebar-menu">
            <li><a href="@Url.Action("AdminDashboard", "Website")">DASHBOARD</a></li>
            <li><a href="@Url.Action("Canteen", "Website")">CANTEEN</a></li>
            <li><a href="@Url.Action("Cgpa", "Website")">CGPA CALCULATION</a></li>
            <li><a href="@Url.Action("EventDetails", "Website")">EVENT DETAILS</a></li>
            <li><a href="@Url.Action("FacultySupport", "Website")">FACULTY SUPPORT</a></li>
            <li><a href="@Url.Action("IdBalance", "Website")">ID BALANCE</a></li>
            <li><a href="@Url.Action("Placement", "Website")">PLACEMENT SUPPORT</a></li>
            <li><a href="@Url.Action("Syllabus", "Website")">SYLLABUS</a></li>
            <li><a href="@Url.Action("Timetable", "Website")">TIMETABLE</a></li>
        </ul>
    </aside>

    <!-- PAGE CONTENT -->
    <main class="page-content">
        @RenderBody()
    </main>

    <!-- JS -->
    <script>
        const openMenu = document.getElementById("openMenu");
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebarOverlay");

        openMenu.addEventListener("click", () => {
            sidebar.classList.add("active");
            overlay.classList.add("active");
        });

        overlay.addEventListener("click", () => {
            sidebar.classList.remove("active");
            overlay.classList.remove("active");
        });
    </script>

    <!-- jQuery (required by pages using $) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Bootstrap JS (optional) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>