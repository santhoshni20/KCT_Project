@{
    Layout = null;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] | KSI</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --bg-main: #000;
            --bg-elevated: #111;
            --text-main: #fff;
            --text-muted: #aaa;
            --border-subtle: rgba(255,255,255,0.1);
        }

        body {
            margin: 0;
            background: var(--bg-main);
            color: var(--text-main);
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* ================= HEADER WITH BACKGROUND IMAGE ================= */
        .top-bar-shell {
            position: fixed;
            inset: 0 0 auto 0;
            z-index: 1000;
        }

        .top-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 24px;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.95) 0%, rgba(118, 75, 162, 0.95) 100%);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
            position: relative;
            overflow: hidden;
        }

            /* Background image overlay */
            .top-bar::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background-image: url('~/images/kct.jpg');
                background-size: cover;
                background-position: center;
                opacity: 0.15;
                z-index: -1;
            }

            /* Animated pattern overlay */
            .top-bar::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
                z-index: -1;
            }

        .brand-block {
            display: flex;
            align-items: center;
            gap: 12px;
            position: relative;
            z-index: 2;
        }

            .brand-block img {
                width: 40px;
                height: 40px;
                border-radius: 8px;
                background: white;
                padding: 4px;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            }

        .brand-text {
            color: white;
            font-size: 1.2rem;
            font-weight: 700;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
            display: none;
        }

        @@media (min-width: 768px) {
            .brand-text

        {
            display: block;
        }

        }

        .menu-btn {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.3);
            width: 40px;
            height: 40px;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 5px;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            z-index: 2;
        }

            .menu-btn:hover {
                background: rgba(255, 255, 255, 0.25);
                transform: scale(1.05);
            }

            .menu-btn span {
                height: 2px;
                background: white;
                width: 20px;
                margin: 0 auto;
                border-radius: 2px;
                transition: all 0.3s ease;
            }

        /* ================= ENHANCED SIDEBAR ================= */
        .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(5px);
            display: none;
            z-index: 999;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: -320px;
            width: 320px;
            height: 100%;
            background: linear-gradient(180deg, #1a1a1a 0%, #0d0d0d 100%);
            padding: 30px 0;
            transition: left 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 1000;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.5);
        }

            .sidebar.active {
                left: 0;
            }

        .sidebar-overlay.active {
            display: block;
        }

        .sidebar-header {
            padding: 0 25px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 20px;
        }

        .sidebar h4 {
            font-size: 0.75rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin: 0;
            font-weight: 600;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0 15px;
            margin: 0;
        }

            .sidebar-menu li {
                margin-bottom: 8px;
            }

            .sidebar-menu a {
                color: var(--text-main);
                text-decoration: none;
                font-size: 0.95rem;
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 15px;
                border-radius: 10px;
                transition: all 0.25s ease;
                font-weight: 500;
                position: relative;
            }

                .sidebar-menu a::before {
                    content: '';
                    width: 4px;
                    height: 0;
                    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                    border-radius: 2px;
                    position: absolute;
                    left: 0;
                    transition: height 0.25s ease;
                }

                .sidebar-menu a:hover {
                    background: rgba(255,255,255,0.08);
                    padding-left: 20px;
                    color: #fff;
                }

                    .sidebar-menu a:hover::before {
                        height: 100%;
                    }

                /* Active menu item */
                .sidebar-menu a.active {
                    background: rgba(102, 126, 234, 0.15);
                    color: #667eea;
                    font-weight: 600;
                }

                    .sidebar-menu a.active::before {
                        height: 100%;
                    }

        /* ================= CONTENT ================= */
        main.page-content {
            padding-top: 80px;
            min-height: 100vh;
            padding-left: 20px;
            padding-right: 20px;
        }

        @@media (min-width: 768px) {
            main .page-content

        {
            padding-left: 40px;
            padding-right: 40px;
        }

        }
    </style>

    @RenderSection("PageStyles", required: false)
</head>

<body>

    <!-- HEADER WITH BACKGROUND -->
    <div class="top-bar-shell">
        <header class="top-bar">
            <div class="brand-block">
                <img src="~/images/ksi.png" alt="KSI Logo" />
                <span class="brand-text">KSI Portal</span>
            </div>

            @* <!-- MENU ICON --> *@
            @* <button class="menu-btn" id="openMenu" aria-label="Open Menu"> *@
            @*     <span></span> *@
            @*     <span></span> *@
            @*     <span></span> *@
            @* </button> *@
        </header>
    </div>

    <!-- SIDEBAR OVERLAY -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- ENHANCED SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h4>Student Services</h4>
        </div>
        <ul class="sidebar-menu">
            <li><a href="@Url.Action("AdminDashboard", "Website")" class="@(currentAction == "AdminDashboard" ? "active" : "")">📊 DASHBOARD</a></li>
            <li><a href="@Url.Action("Canteen", "Website")" class="@(currentAction == "Canteen" ? "active" : "")">🍽️ CANTEEN</a></li>
            <li><a href="@Url.Action("Cgpa", "Website")" class="@(currentAction == "Cgpa" ? "active" : "")">📈 CGPA CALCULATION</a></li>
            <li><a href="@Url.Action("EventDetails", "Website")" class="@(currentAction == "EventDetails" ? "active" : "")">🎉 EVENT DETAILS</a></li>
            <li><a href="@Url.Action("FacultySupport", "Website")" class="@(currentAction == "FacultySupport" ? "active" : "")">👨‍🏫 FACULTY SUPPORT</a></li>
            <li><a href="@Url.Action("HallLocator", "Website")" class="@(currentAction == "HallLocator" ? "active" : "")">🗺️ HALL LOCATOR</a></li>
            <li><a href="@Url.Action("IdBalance", "Website")" class="@(currentAction == "IdBalance" ? "active" : "")">💳 ID BALANCE</a></li>
            <li><a href="@Url.Action("Placement", "Website")" class="@(currentAction == "Placement" ? "active" : "")">🚀 PLACEMENT SUPPORT</a></li>
            <li><a href="@Url.Action("Syllabus", "Website")" class="@(currentAction == "Syllabus" ? "active" : "")">📚 SYLLABUS</a></li>
            <li><a href="@Url.Action("Timetable", "Website")" class="@(currentAction == "Timetable" ? "active" : "")">📅 TIMETABLE</a></li>
        </ul>
    </aside>

    <!-- PAGE CONTENT -->
    <main class="page-content">
        @RenderBody()
    </main>

    <!-- JS -->
    <script>
        const openMenu = document.getElementById("openMenu");
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebarOverlay");

        openMenu.addEventListener("click", () => {
            sidebar.classList.add("active");
            overlay.classList.add("active");
        });

        overlay.addEventListener("click", () => {
            sidebar.classList.remove("active");
            overlay.classList.remove("active");
        });

        // Close sidebar on ESC key
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && sidebar.classList.contains("active")) {
                sidebar.classList.remove("active");
                overlay.classList.remove("active");
            }
        });
    </script>

    <!-- jQuery (required by pages using $) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- Bootstrap JS (optional) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
