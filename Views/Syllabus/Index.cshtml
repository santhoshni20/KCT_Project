@{
    ViewData["Title"] = "Syllabus";
}

<!-- Font Awesome & Bootstrap -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<style>
    /* ✅ Only affects syllabus section, not entire body */
    .syllabus-container {
        background: linear-gradient(135deg, #007bff, #6610f2);
        color: #fff;
        font-family: "Poppins", sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        padding: 40px 0;
    }

    .page-container {
        background: #ffffff;
        color: #333;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        padding: 40px 50px;
        text-align: center;
        width: 90%;
        max-width: 550px;
        animation: fadeIn 0.8s ease-in-out;
    }

        .page-container h2 {
            font-weight: 700;
            margin-bottom: 25px;
            color: #0d6efd;
        }

    .batch-section {
        margin-bottom: 25px;
        text-align: left;
    }

    .batch-label {
        font-size: 1rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: block;
    }

    .form-select {
        border-radius: 10px;
        padding: 10px;
        box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .form-select:focus {
            transform: scale(1.03);
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.3);
        }

    .download-btn {
        font-size: 1.1rem;
        font-weight: 600;
        background: linear-gradient(90deg, #007bff, #6610f2);
        color: white;
        padding: 12px 25px;
        border-radius: 12px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: transform 0.2s, box-shadow 0.2s, background 0.3s;
    }

        .download-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 15px rgba(0, 123, 255, 0.4);
        }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(15px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    footer {
        margin-top: 20px;
        font-size: 0.85rem;
        color: rgba(0, 0, 0, 0.6);
    }
</style>

<!-- ✅ Gradient background confined to syllabus area only -->
<div class="syllabus-container">
    <div class="page-container">
        <h2><i class="fas fa-book-open"></i> Syllabus Portal</h2>

        <!-- Batch Dropdown -->
        <div class="batch-section">
            <label class="batch-label"><i class="fas fa-users"></i> Select Batch</label>
            <select class="form-select" id="batchDropdown">
                <option value="">-- Select Batch --</option>
                <option value="2022-2026">2022 - 2026</option>
                <option value="2023-2027">2023 - 2027</option>
                <option value="2024-2028">2024 - 2028</option>
                <option value="2025-2029">2025 - 2029</option>
            </select>
        </div>

        <!-- Department Dropdown -->
        <div class="batch-section">
            <label class="batch-label"><i class="fas fa-building"></i> Select Department</label>
            <select class="form-select" id="deptDropdown" disabled>
                <option value="">-- Select Department --</option>
            </select>
        </div>

        <!-- Download Button -->
        <button class="download-btn" id="downloadBtn">
            <i class="fas fa-download"></i> Download Syllabus
        </button>

        <footer>
            <p>© 2025 KCT Syllabus Portal | Powered by ASP.NET Core</p>
        </footer>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const deptOptions = [
            { value: "AI_DS", text: "Artificial Intelligence and Data Science" },
            { value: "CSE", text: "Computer Science and Engineering" },
            { value: "IT", text: "Information Technology" }
        ];

        document.getElementById("batchDropdown").addEventListener("change", function () {
            var batch = this.value;
            var deptDropdown = document.getElementById("deptDropdown");
            deptDropdown.innerHTML = "<option value=''>-- Select Department --</option>";

            if (batch) {
                deptOptions.forEach(d => {
                    var opt = document.createElement("option");
                    opt.value = d.value;
                    opt.text = d.text;
                    deptDropdown.appendChild(opt);
                });
                deptDropdown.disabled = false;
            } else {
                deptDropdown.disabled = true;
            }
        });

        document.getElementById("downloadBtn").addEventListener("click", function () {
            var batch = document.getElementById("batchDropdown").value;
            var dept = document.getElementById("deptDropdown").value;

            if (!batch) {
                alert("Please select a batch before downloading!");
                return;
            }
            if (!dept) {
                alert("Please select a department before downloading!");
                return;
            }

            fetch(`/Syllabus/DownloadSyllabus?batch=${batch}&dept=${dept}`)
                .then(response => {
                    if (response.redirected) {
                        window.open(response.url, "_blank");
                    } else {
                        return response.json();
                    }
                })
                .then(data => {
                    if (data && data.statusCode !== 200) {
                        alert(data.message || "Syllabus not found!");
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert("Error downloading syllabus.");
                });
        });
    </script>
}
