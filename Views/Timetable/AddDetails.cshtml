@{
    ViewData["Title"] = "Add Details";
}

<style>
    /* ===== GLOBAL RESET & SAFETY ===== */
    *,
    *::before,
    *::after {
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow-x: hidden; /* 🔥 critical */
    }

    /* ===== PAGE LAYOUT ===== */
    .page-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 30px;
    }

    .page-header {
        text-align: center;
        margin-bottom: 35px;
        color: white;
    }

    /* ===== INPUT CARD ===== */
    .input-card {
        background: #fff;
        border-radius: 18px;
        padding: 25px;
        box-shadow: 0 12px 30px rgba(0,0,0,0.2);
        margin-bottom: 30px;
    }

    /* GRID */
    .input-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr)); /* 🔥 FIX */
        gap: 25px;
    }

    /* FLEX CONTAINER */
    .input-box {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0; /* 🔥 FIX */
    }

        /* INPUT */
        .input-box input {
            flex: 1;
            min-width: 0; /* 🔥 FIX */
            height: 44px;
            padding: 0 18px;
            border-radius: 25px;
            border: 1px solid #ccc;
            font-size: 15px;
            outline: none;
        }

            .input-box input:focus {
                border-color: #667eea;
            }

    /* ===== PLUS BUTTON ===== */
    .icon-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: none;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        font-size: 22px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0; /* 🔥 FIX */
    }

    /* ===== TOGGLE SWITCH ===== */
    .toggle-wrapper {
        display: flex;
        align-items: center;
        height: 44px;
        flex-shrink: 0; /* 🔥 FIX */
    }

    .toggle-switch {
        position: relative;
        width: 52px;
        height: 28px;
    }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    /* SLIDER */
    .toggle-slider {
        position: absolute;
        inset: 0;
        cursor: pointer;
        background-color: #cfcfcf;
        border-radius: 30px;
        transition: background 0.3s ease;
    }

        .toggle-slider::before {
            content: "";
            position: absolute;
            height: 22px;
            width: 22px;
            left: 3px;
            top: 3px;
            background-color: #fff;
            border-radius: 50%;
            transition: transform 0.3s ease;
            box-shadow: 0 2px 6px rgba(0,0,0,0.3);
        }

    .toggle-switch input:checked + .toggle-slider {
        background: linear-gradient(135deg, #667eea, #764ba2);
    }

        .toggle-switch input:checked + .toggle-slider::before {
            transform: translateX(24px);
        }

    /* ===== TABLE GRID ===== */
    .table-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr)); /* 🔥 FIX */
        gap: 20px;
    }

    /* CARD */
    .table-card {
        background: #fff;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        overflow-x: hidden;
    }

    /* TABLE */
    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #667eea;
        color: white;
        padding: 12px;
        text-align: left;
    }

    td {
        padding: 10px;
        border-bottom: 1px solid #ddd;
    }
</style>

<div class="page-container">

    <div class="page-header">
        <h1>📅 Timetable – Add Details</h1>
        <p>Batch | Department | Section</p>
    </div>

    <!-- INPUT SECTION -->
    <div class="input-card">
        <div class="input-row">

            <!-- Batch -->
            <div class="input-box">
                <input type="text" id="batchName" placeholder="Batch" />
                <button class="icon-btn" onclick="saveBatch()">+</button>
                <div class="toggle-wrapper">
                    <label class="toggle-switch">
                        <input type="checkbox" checked />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <!-- Department -->
            <div class="input-box">
                <input type="text" id="departmentName" placeholder="Department" />
                <button class="icon-btn" onclick="saveDepartment()">+</button>
                <div class="toggle-wrapper">
                    <label class="toggle-switch">
                        <input type="checkbox" checked />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

            <!-- Section -->
            <div class="input-box">
                <input type="text" id="sectionName" placeholder="Section" />
                <button class="icon-btn" onclick="saveSection()">+</button>
                <div class="toggle-wrapper">
                    <label class="toggle-switch">
                        <input type="checkbox" checked />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>

        </div>
    </div>

    <!-- TABLES -->
    <div class="table-grid">

        <div class="table-card">
            <h4>Batch List</h4>
            <table>
                <thead>
                    <tr><th>#</th><th>Batch Name</th></tr>
                </thead>
                <tbody id="batchTable"></tbody>
            </table>
        </div>

        <div class="table-card">
            <h4>Department List</h4>
            <table>
                <thead>
                    <tr><th>#</th><th>Department Name</th></tr>
                </thead>
                <tbody id="departmentTable"></tbody>
            </table>
        </div>

        <div class="table-card">
            <h4>Section List</h4>
            <table>
                <thead>
                    <tr><th>#</th><th>Section Name</th></tr>
                </thead>
                <tbody id="sectionTable"></tbody>
            </table>
        </div>

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', loadTables);

    function loadTables() {
        fetch('/api/timetable/dropdowns')
            .then(r => r.json())
            .then(res => {
                if (!res.success) return;
                fillTable('batchTable', res.data.batches);
                fillTable('departmentTable', res.data.departments);
                fillTable('sectionTable', res.data.sections);
            });
    }

    function fillTable(id, data) {
        const tbody = document.getElementById(id);
        tbody.innerHTML = '';
        data.forEach((x, i) => {
            tbody.innerHTML += `
                <tr>
                    <td>${i + 1}</td>
                    <td>${x.name}</td>
                </tr>`;
        });
    }

    function saveBatch() {
        postData('/api/timetable/batch', { name: batchName.value });
        batchName.value = '';
    }

    function saveDepartment() {
        postData('/api/timetable/department', { name: departmentName.value });
        departmentName.value = '';
    }

    function saveSection() {
        postData('/api/timetable/section', { name: sectionName.value });
        sectionName.value = '';
    }

    function postData(url, data) {
        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(res => {
            alert(res.message);
            if (res.success) loadTables();
        });
    }
</script>
