@{
    Layout = "_Layout";
    ViewData["Title"] = "Master Details";
}

<h4 class="fw-bold mb-3">Master Details</h4>

<!-- INLINE ADD BAR -->
<div class="card p-3 mb-4">
    <div class="d-flex gap-3 align-items-center flex-wrap">

        <!-- Batch -->
        <div class="d-flex align-items-center master-input">
            <input type="text" id="batchName" class="form-control rounded-pill" placeholder="Batch" />
            <button class="btn btn-primary rounded-circle ms-2"
                    onclick="addBatch()">
                <i class="bx bx-plus"></i>
            </button>
        </div>

        <!-- Department -->
        <div class="d-flex align-items-center master-input">
            <input type="text" id="departmentName" class="form-control rounded-pill" placeholder="Department" />
            <button class="btn btn-primary rounded-circle ms-2"
                    onclick="addDepartment()">
                <i class="bx bx-plus"></i>
            </button>
        </div>

        <!-- Section -->
        <div class="d-flex align-items-center master-input">
            <input type="text" id="sectionName" class="form-control rounded-pill" placeholder="Section" />
            <button class="btn btn-primary rounded-circle ms-2"
                    onclick="addSection()">
                <i class="bx bx-plus"></i>
            </button>
        </div>

        <!-- Subject -->
        <div class="d-flex align-items-center master-input">
            <input type="text" id="subjectName" class="form-control rounded-pill" placeholder="Subject" />
            <button class="btn btn-primary rounded-circle ms-2"
                    onclick="addSubject()">
                <i class="bx bx-plus"></i>
            </button>
        </div>
        <!-- Block -->
        <div class="d-flex align-items-center master-input">
            <input type="text" id="blockName" class="form-control rounded-pill" placeholder="Block" />
            <button class="btn btn-primary rounded-circle ms-2"
                    onclick="addBlock()">
                <i class="bx bx-plus"></i>
            </button>
        </div>

        <!-- Room -->
        <div class="d-flex align-items-center master-input">
            <input type="text" id="roomNumber" class="form-control rounded-pill" placeholder="Room No" />
            <button class="btn btn-primary rounded-circle ms-2"
                    onclick="addRoom()">
                <i class="bx bx-plus"></i>
            </button>
        </div>

    </div>
</div>

<!-- MASTER TABLE -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-bordered text-center align-middle">
            <thead class="table-primary">
                <tr>
                    <th>Batch</th>
                    <th>Department</th>
                    <th>Section</th>
                    <th>Subject</th>
                    <th>Block</th>
                    <th>Room</th>
                </tr>
            </thead>
            <tbody id="masterBody"></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>

        document.addEventListener('DOMContentLoaded', loadMasterData);

        function loadMasterData() {
            fetch('/Timetable/GetMasterData')
                .then(r => r.json())
                .then(res => {
                    if (!res.success) return;

                    const b = res.data.batches;
                    const d = res.data.departments;
                    const s = res.data.sections;
                    const sub = res.data.subjects;
                    const bl = res.data.blocks;
                    const r = res.data.rooms;

                    const max = Math.max(
                        b.length,
                        d.length,
                        s.length,
                        sub.length,
                        bl.length,
                        r.length
                    );

                    let rows = '';

                    for (let i = 0; i < max; i++) {
                        rows += `<tr>
                            <td>${cell(b[i], 'batch')}</td>
                            <td>${cell(d[i], 'department')}</td>
                            <td>${cell(s[i], 'section')}</td>
                            <td>${cell(sub[i], 'subject')}</td>
                            <td>${cell(bl[i], 'block')}</td>
                            <td>${cell(r[i], 'room')}</td>
                        </tr>`;
                    }

                    document.getElementById('masterBody').innerHTML = rows;

                });
        }

        function cell(item, type) {
            if (!item) return '';
            return `
                <div class="d-flex justify-content-between align-items-center">
                    <span>${item.name}</span>
                    <input type="checkbox"
                           ${item.isActive ? 'checked' : ''}
                           onchange="toggleStatus('${type}', ${item.id}, this.checked)">
                </div>`;
        }

        function toggleStatus(type, id, status) {
            let payload = { isActive: status };
            payload[type + 'Id'] = id;

            fetch('/Timetable/ToggleStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(() => loadMasterData());
        }

        /* ========== ADD ========= */

        function addBatch() {
            addSimple('/Timetable/AddBatch', 'batchName');
        }

        function addDepartment() {
            addSimple('/Timetable/AddDepartment', 'departmentName');
        }

        function addSection() {
            addSimple('/Timetable/AddSection', 'sectionName');
        }
        function addBlock() {
            addSimple('/Timetable/AddBlock', 'blockName');
        }

        function addRoom() {
            addSimple('/Timetable/AddRoom', 'roomNumber');
        }

        function addSubject() {
            const name = document.getElementById('subjectName').value.trim();
            if (!name) {
                alert('Enter subject name');
                return;
            }

            // TEMP DEFAULT IDs (until you add dropdowns)
            fetch('/Timetable/AddSubject', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    subjectName: name,
                    batchId: 1,
                    departmentId: 1,
                    sectionId: 1,
                    createdBy: 1
                })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    document.getElementById('subjectName').value = '';
                    loadMasterData();
                } else {
                    alert(res.message);
                }
            });
        }

        function addSimple(url, inputId) {
            const name = document.getElementById(inputId).value.trim();
            if (!name) return;

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    document.getElementById(inputId).value = '';
                    loadMasterData();
                } else {
                    alert(res.message);
                }
            });
        }

    </script>
}
