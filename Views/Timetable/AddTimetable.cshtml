@{
    Layout = "_Layout";
    ViewData["Title"] = "Add Timetable";
}

<div class="d-flex justify-content-between mb-3">
    <h4 class="fw-bold">Timetable Details</h4>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#timetableModal">
        <i class="bx bx-plus"></i> Add Timetable
    </button>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Day</th>
                    <th>Batch</th>
                    <th>Department</th>
                    <th>Section</th>
                    <th>Subject</th>   
                    <th>Block</th>   
                    <th>Room</th>     
                    <th>Hour</th>
                    <th>Faculty</th>
                </tr>
            </thead>
            <tbody id="timetableBody"></tbody>
        </table>
    </div>
</div>

<!-- MODAL -->
<div class="modal fade" id="timetableModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Add Timetable</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="timetableForm">
                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">Batch</label>
                            <select id="batch" class="form-control"></select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Department</label>
                            <select id="department" class="form-control"></select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Section</label>
                            <select id="section" class="form-control"></select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Subject</label>
                            <select id="subject" class="form-control"></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Day</label>
                            <select id="day" class="form-control">
                                <option value="">Select Day</option>
                                <option>Sunday</option>
                                <option>Monday</option>
                                <option>Tuesday</option>
                                <option>Wednesday</option>
                                <option>Thursday</option>
                                <option>Friday</option>
                                <option>Saturday</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Block</label>
                            <select id="block" class="form-control"></select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Room</label>
                            <select id="room" class="form-control"></select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Hour (1 - 7)</label>
                            <input type="number" id="hour" min="1" max="7" class="form-control" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Faculty</label>
                            <select id="faculty" class="form-control"></select>
                        </div>

                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="saveTimetable()">Save</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            loadDropdowns();
            loadTimetable();
        });

        function loadDropdowns() {
            fetch('/Timetable/GetDropdowns')
                .then(r => r.json())
                .then(res => {
                    if (!res.success) return;

                    fill('batch', res.data.batches);
                    fill('department', res.data.departments);
                    fill('section', res.data.sections);
                    fill('subject', res.data.subjects);
                    fill('faculty', res.data.faculties);
                    fill('block', res.data.blocks);   // ✅
                    fill('room', res.data.rooms);     // ✅
                });
        }

        function fill(id, data) {
            const ddl = document.getElementById(id);
            ddl.innerHTML = '<option value="">Select</option>';
            data.forEach(x => {
                ddl.innerHTML += `<option value="${x.id}">${x.name}</option>`;
            });
        }

        function saveTimetable() {
            if (!day.value || !block.value || !room.value) {
                alert("Please select Day, Block and Room");
                return;
            }

            const payload = {
                batchId: batch.value,
                departmentId: department.value,
                sectionId: section.value,
                subjectId: subject.value,
                facultyId: faculty.value,
                hourNo: hour.value,
                day: day.value,
                blockId: block.value,
                roomId: room.value
            };

            fetch('/Timetable/SaveTimetable', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(r => r.json())
            .then(res => {
                alert(res.message);
                if (res.success) {
                    timetableForm.reset();
                    $('#timetableModal').modal('hide');
                    loadTimetable();
                }
            });
        }

        function loadTimetable() {
            fetch('/Timetable/GetTimetableList')
                .then(res => res.json())
                .then(res => {
                    if (!res.success) return;

                    const body = document.getElementById('timetableBody');
                    body.innerHTML = '';

                    res.data.forEach(x => {
                        body.innerHTML += `
                            <tr>
                                <td>${x.day}</td>
                                <td>${x.batch}</td>
                                <td>${x.department}</td>
                                <td>${x.section}</td>
                                <td>${x.subject}</td>   <!-- ✅ -->
                                <td>${x.block}</td>     <!-- ✅ -->
                                <td>${x.room}</td>      <!-- ✅ -->
                                <td>${x.hour}</td>
                                <td>${x.faculty}</td>
                            </tr>
                        `;
                    });
                });
        }

    </script>
}
