@{
    ViewData["Title"] = "Timetable";
}

<!-- Bootstrap & Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<style>
    body {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        min-height: 100vh;
        font-family: 'Poppins', sans-serif;
        color: #fff;
    }

    .page-container {
        margin-top: 60px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: start;
        min-height: 100vh;
        padding-bottom: 100px;
    }

    .header-title {
        font-size: 2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        background: rgba(255, 255, 255, 0.2);
        padding: 10px 25px;
        border-radius: 20px;
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        margin-bottom: 40px;
    }

    .dropdown-section {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
        margin-bottom: 40px;
    }

    .dropdown-card {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 15px;
        padding: 20px 30px;
        min-width: 280px;
        transition: all 0.3s ease-in-out;
    }

        .dropdown-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
        }

    .batch-label {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        text-align: left;
    }

    select.form-select {
        border-radius: 10px;
        border: none;
        padding: 10px;
        font-size: 0.95rem;
        background: rgba(255, 255, 255, 0.85);
        color: #333;
        transition: box-shadow 0.2s;
    }

        select.form-select:focus {
            box-shadow: 0 0 0 0.25rem rgba(111, 66, 193, 0.5);
        }

    .table-container {
        margin-top: 30px;
        width: 90%;
        max-width: 700px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        padding: 20px;
        backdrop-filter: blur(10px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.25);
    }

    table {
        width: 100%;
        text-align: center;
        color: #fff;
        border-collapse: collapse;
    }

    th, td {
        padding: 12px;
        border: 1px solid rgba(255, 255, 255, 0.25);
    }

    th {
        background: rgba(255, 255, 255, 0.25);
        font-weight: 700;
        text-transform: uppercase;
    }

    tr:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    tbody tr {
        transition: all 0.2s ease-in-out;
    }

    tbody td {
        font-size: 1rem;
    }

    .no-data {
        text-align: center;
        font-weight: 600;
        color: #fff;
        opacity: 0.8;
    }
</style>

<div class="container page-container">
    <div class="header-title text-center">
        <i class="fa-solid fa-calendar-days me-2"></i>Timetable Viewer
    </div>

    <!-- Dropdowns Section -->
    <div class="dropdown-section">

        <div class="dropdown-card">
            <label class="batch-label"><i class="fa-solid fa-users-line me-2"></i>Batch</label>
            <select class="form-select" id="batchDropdown">
                <option value="">-- Select Batch --</option>
                <option value="2022">2022 - 2026</option>
                <option value="2023">2023 - 2027</option>
                <option value="2024">2024 - 2028</option>
                <option value="2025">2025 - 2029</option>
            </select>
        </div>

        <div class="dropdown-card">
            <label class="batch-label"><i class="fa-solid fa-building-columns me-2"></i>Department with Sec</label>
            <select class="form-select" id="deptDropdown" disabled>
                <option value="">-- Select Department --</option>
            </select>
        </div>

        <div class="dropdown-card">
            <label class="batch-label"><i class="fa-solid fa-calendar-day me-2"></i>Day</label>
            <select class="form-select" id="dayDropdown" disabled>
                <option value="">-- Select Day --</option>
                <option value="Monday">Monday</option>
                <option value="Tuesday">Tuesday</option>
                <option value="Wednesday">Wednesday</option>
                <option value="Thursday">Thursday</option>
                <option value="Friday">Friday</option>
            </select>
        </div>

    </div>

    <!-- Timetable Table -->
    <div class="table-container">
        <table class="table" id="timetableTable">
            <thead>
                <tr>
                    <th>Hour</th>
                    <th>Subject</th>
                </tr>
            </thead>
            <tbody>
                <tr><td colspan="2" class="no-data">Select batch, department & day</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const deptOptions = [
            { value: "AIDS-A", text: "AI & DS - Sec A" },
            { value: "AIDS-B", text: "AI & DS - Sec B" },
            { value: "CSE-A", text: "CSE - Sec A" },
            { value: "CSE-B", text: "CSE - Sec B" },
            { value: "IT-A", text: "IT - Sec A" },
            { value: "IT-B", text: "IT - Sec B" }
        ];

        const batchDropdown = document.getElementById("batchDropdown");
        const deptDropdown = document.getElementById("deptDropdown");
        const dayDropdown = document.getElementById("dayDropdown");
        const timetableBody = document.querySelector("#timetableTable tbody");

        batchDropdown.addEventListener("change", function () {
            const batch = this.value;
            deptDropdown.innerHTML = "<option value=''>-- Select Department --</option>";
            dayDropdown.value = "";
            dayDropdown.disabled = true;
            timetableBody.innerHTML = "<tr><td colspan='2' class='no-data'>Select batch, department & day</td></tr>";

            if (batch) {
                deptOptions.forEach(d => {
                    const opt = document.createElement("option");
                    opt.value = d.value;
                    opt.text = d.text;
                    deptDropdown.appendChild(opt);
                });
                deptDropdown.disabled = false;
            } else {
                deptDropdown.disabled = true;
            }
        });

        // Enable day after selecting department
        deptDropdown.addEventListener("change", function () {
            dayDropdown.value = "";
            dayDropdown.disabled = !this.value;
            timetableBody.innerHTML = "<tr><td colspan='2' class='no-data'>Select batch, department & day</td></tr>";
        });

        dayDropdown.addEventListener("change", function () {
            const batch = batchDropdown.value;
            const dept = deptDropdown.value;
            const day = this.value;

            if (batch && dept && day) {
                const [department, section] = dept.split('-');

                fetch(`/Timetable/GetByDay?batch=${batch}&dept=${department}&section=${section}&day=${day.toLowerCase()}`)
                    .then(response => response.json())
                    .then(resp => {
                        timetableBody.innerHTML = "";

                        if (resp.statusCode === 200 && resp.data.length > 0) {
                            for (let hour = 1; hour <= 7; hour++) {
                                const rowData = resp.data.find(r => parseInt(r.hourNo) === hour);
                                const tr = document.createElement("tr");
                                tr.innerHTML = `
                                    <td>${hour}</td>
                                    <td>${rowData ? rowData.subject : "-"}</td>
                                `;
                                timetableBody.appendChild(tr);
                            }
                        } else {
                            timetableBody.innerHTML = `<tr><td colspan='2' class='no-data'>${resp.message}</td></tr>`;
                        }
                    })
                    .catch(err => {
                        timetableBody.innerHTML = "<tr><td colspan='2' class='no-data'>Error loading timetable</td></tr>";
                        console.error(err);
                    });
            }
        });
    </script>
}
