@* Views/Website/Canteen.cshtml *@
@model IEnumerable<KSI_Project.Models.Entity.CanteenId>
@{
    ViewData["Title"] = "College Canteens";
}

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .canteen-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 30px;
    }

    .canteen-header {
        text-align: center;
        margin-bottom: 50px;
        color: white;
    }

        .canteen-header h1 {
            font-size: 3rem;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            margin-bottom: 10px;
        }

        .canteen-header p {
            font-size: 1.2rem;
            opacity: 0.9;
        }

    .canteen-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        padding: 20px;
    }

    .canteen-card {
        background: white;
        border-radius: 20px;
        padding: 30px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .canteen-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: linear-gradient(90deg, #667eea, #764ba2);
        }

        .canteen-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        }

    .canteen-icon {
        font-size: 4rem;
        margin-bottom: 20px;
    }

    .canteen-card h2 {
        font-size: 1.8rem;
        color: #333;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .view-menu-btn {
        display: inline-block;
        padding: 12px 30px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        text-decoration: none;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
    }

        .view-menu-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
            color: white;
        }

    .back-home {
        text-align: center;
        margin-top: 30px;
    }

        .back-home a {
            color: white;
            text-decoration: none;
            font-size: 1.1rem;
            padding: 10px 20px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 25px;
            transition: all 0.3s ease;
        }

            .back-home a:hover {
                background: rgba(255, 255, 255, 0.3);
            }
</style>

<div class="canteen-container">
    <div class="canteen-header">
        <h1>🍽️ College Canteens</h1>
        <p>Choose your favorite canteen and explore the menu</p>
    </div>
    <div class="canteen-grid">
        @if (Model == null || !Model.Any())
        {
            <p style="color:white; text-align:center;">
                No canteens available right now.
            </p>
        }
        else
        {
            foreach (var canteen in Model)
            {
                <div class="canteen-card">
                    <div class="canteen-icon">
                        @switch (canteen.CanteenID)
                        {
                            case 1:
                                @Html.Raw("☕")
                                break;
                            case 2:
                                @Html.Raw("🍔")
                                break;
                            case 3:
                                @Html.Raw("🍕")
                                break;
                            case 4:
                                @Html.Raw("🍱")
                                break;
                            case 5:
                                @Html.Raw("🍛")
                                break;
                            case 6:
                                @Html.Raw("🫖")
                                break;
                            default:
                                @Html.Raw("🍽️")
                                break;
                        }
                    </div>
                    <h2>@canteen.CanteenName</h2>
                    <a href="@Url.Action("CanteenMenu", "Website", new { canteenId = canteen.CanteenID })"
                       class="view-menu-btn">
                        View Menu 🔍
                    </a>
                </div>
            }
        }
    </div>


    <a href="@Url.Action("AdminDashboard", "Website")">← Back to Home</a>
</div>