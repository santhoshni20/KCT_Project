@{
    ViewData["Title"] = "CGPA Calculator";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .cgpa-container {
        max-width: 1100px;
        margin: 40px auto;
        padding: 30px;
    }

    .cgpa-header {
        text-align: center;
        margin-bottom: 40px;
        color: white;
    }

        .cgpa-header h1 {
            font-size: 3rem;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .cgpa-header p {
            font-size: 1.2rem;
            opacity: 0.9;
        }

    .cgpa-card {
        background: white;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        margin-bottom: 30px;
    }

    .form-select {
        border-radius: 12px;
        padding: 10px;
    }

    .table thead {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .table th,
    .table td {
        text-align: center;
        vertical-align: middle;
    }

    .btn-calc {
        padding: 12px 30px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 50px;
        font-weight: 600;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-calc:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
            color: white;
        }
</style>

<div class="cgpa-container">

    <!-- Header -->
    <div class="cgpa-header">
        <h1>🎓 CGPA Calculator</h1>
        <p>Select your batch & department</p>
    </div>

    <!-- Batch & Department -->
    <div class="cgpa-card">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Batch</label>
                <select id="ddlBatch" class="form-select">
                    <option value="">-- Select Batch --</option>
                </select>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Department</label>
                <select id="ddlDepartment" class="form-select">
                    <option value="">-- Select Department --</option>
                </select>
            </div>
        </div>
    </div>

    <!-- CGPA Table -->
    <div class="cgpa-card">
        <h5 class="fw-bold mb-3">Subjects</h5>

        <div class="table-responsive">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th style="width:70%">Subject</th>
                        <th style="width:30%">Grade</th>
                    </tr>
                </thead>
                <tbody id="cgpaSubjectsBody">
                    <tr>
                        <td colspan="2" class="text-center text-muted">Select batch and department to load subjects</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="text-center mt-4">
            <button id="btnCalculate" class="btn-calc">
                <i class="fa-solid fa-calculator me-2"></i> Calculate CGPA
            </button>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    <script>
        $(document).ready(function () {
            loadBatches();
            loadDepartments();

            // wire change handlers
            $("#ddlBatch, #ddlDepartment").on("change", function () {
                loadSubjectsForCgpa();
            });

            // optional: calculate button handler (placeholder)
            $("#btnCalculate").on("click", function () {
                alert("Calculation not implemented in this change. Subjects will be loaded above.");
            });
        });

        function loadBatches() {
            $.ajax({
                url: '@Url.Action("getBatches", "Website")',
                type: 'GET',
                success: function (res) {
                    if (!res || !res.success) return;

                    $("#ddlBatch").empty()
                        .append('<option value="">-- Select Batch --</option>');

                    $.each(res.data, function (i, item) {
                        $("#ddlBatch").append(
                            `<option value="${item.batchId}">${item.batchName ?? item.batchYear ?? ''}</option>`
                        );
                    });
                },
                error: function (err) {
                    console.error(err);
                    alert("Error loading batches");
                }
            });
        }

        function loadDepartments() {
            $.ajax({
                url: '@Url.Action("getDepartments", "Website")',
                type: 'GET',
                success: function (res) {
                    if (!res || !res.success) return;

                    $("#ddlDepartment").empty()
                        .append('<option value="">-- Select Department --</option>');

                    $.each(res.data, function (i, item) {
                        $("#ddlDepartment").append(
                            `<option value="${item.departmentId}">${item.departmentName}</option>`
                        );
                    });
                },
                error: function (err) {
                    console.error(err);
                    alert("Error loading departments");
                }
            });
        }

        function loadSubjectsForCgpa() {
            const batchId = parseInt($("#ddlBatch").val(), 10) || 0;
            const departmentId = parseInt($("#ddlDepartment").val(), 10) || 0;

            if (!batchId || !departmentId) {
                $("#cgpaSubjectsBody").html('<tr><td colspan="2" class="text-center text-muted">Select batch and department to load subjects</td></tr>');
                return;
            }

            $.ajax({
                url: '@Url.Action("getSubjectsForCgpa", "Website")',
                type: 'GET',
                data: { batchId: batchId, departmentId: departmentId },
                success: function (res) {
                    // controller returns ApiResponseDTO { statusCode, success, message, data }
                    if (!res) {
                        console.error("Invalid response from server", res);
                        $("#cgpaSubjectsBody").html('<tr><td colspan="2" class="text-center text-danger">Error loading subjects</td></tr>');
                        return;
                    }

                    if (!res.success) {
                        console.warn("Server returned failure", res.message);
                        $("#cgpaSubjectsBody").html(`<tr><td colspan="2" class="text-center text-warning">${res.message || 'No subjects'}</td></tr>`);
                        return;
                    }

                    const list = res.data || [];
                    if (list.length === 0) {
                        $("#cgpaSubjectsBody").html('<tr><td colspan="2" class="text-center text-muted">No subjects found for selected batch/department</td></tr>');
                        return;
                    }

                    let html = '';
                    list.forEach(s => {
                        const credits = s.numberOfCredits ?? 0;
                        html += `
                            <tr>
                                <td class="text-start">
                                    ${s.subjectName}
                                    <small class="text-muted ms-2">(${credits} cr)</small>
                                </td>
                                <td>
                                    <select class="form-select grade-select">
                                        <option value="" selected disabled>-- Select --</option>
                                        <option>O</option>
                                        <option>A+</option>
                                        <option>A</option>
                                        <option>B+</option>
                                        <option>B</option>
                                        <option>C+</option>
                                        <option>C</option>
                                        <option>U</option>
                                    </select>
                                </td>
                            </tr>
                        `;
                    });

                    $("#cgpaSubjectsBody").html(html);
                },
                error: function (err) {
                    console.error(err);
                    $("#cgpaSubjectsBody").html('<tr><td colspan="2" class="text-center text-danger">Error loading subjects</td></tr>');
                }
            });
        }
    </script>
}