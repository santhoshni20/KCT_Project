@{
    ViewData["Title"] = "Event Details";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<style>
    .event-section {
        margin-bottom: 40px;
    }

    .event-row {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    .event-card {
        width: auto;
        height: 280px; 
        background-color: #2c2c2c;
        border-radius: 15px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        padding: 15px;
        color: white;
        text-align: center;
        display: flex;
        flex-direction: column;
    }


        .event-card img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 50%;
            border: 3px solid white;
            margin-bottom: 10px;
            align-self: center;
        }

        .event-card h5 {
            font-size: 1.1rem;
            font-weight: bold;
            margin-bottom: 5px;
            min-height: 42px; /* ⭐ keeps title area same */
        }

        .event-card p {
            font-size: 0.9rem;
            color: #bbb;
            margin-bottom: 10px;
            min-height: 40px; /* ⭐ keeps organiser text same */
        }

    .btn-view {
        margin-top: auto; /* ⭐ pushes button to bottom */
        background-color: #ff4d4d;
        border: none;
        padding: 6px 14px;
        border-radius: 8px;
        color: white;
        font-size: 0.85rem;
        cursor: pointer;
    }


        .btn-view:hover {
            background-color: #e63e3e;
        }

    .event-scroll {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        gap: 20px;
        padding-bottom: 10px;
    }

        .event-scroll::-webkit-scrollbar {
            height: 8px;
        }

        .event-scroll::-webkit-scrollbar-thumb {
            background: #555;
            border-radius: 4px;
        }

    .event-row,
    .event-scroll {
        display: flex;
        gap: 20px;
    }

        .event-row .event-card,
        .event-scroll .event-card {
            flex: 0 0 200px; /* 🔥 forces exact width */
        }

</style>

<div class="container mt-5">
    <h2 class="mb-4">Event Details</h2>

    <div id="eventsContainer"></div>
</div>

<!-- Event Details Modal -->
<div class="modal fade" id="eventDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content p-4">
            <h4 id="eventDetailsTitle"></h4>
            <p><strong>Date:</strong> <span id="eventDetailsDate"></span></p>
            <p><strong>Deadline:</strong> <span id="eventDetailsDeadline"></span></p>
            <p><strong>Contact:</strong> <span id="eventDetailsContact"></span></p>
            <p><strong>Description:</strong> <span id="eventDetailsDescription"></span></p>
            <div id="eventDetailsBrochure"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            loadEvents();
        });

        function loadEvents() {
            $.get('/Website/GetAllEvents', function (res) {
                if (!res || !res.data) return;

                let grouped = {};
                let today = new Date();
                today.setHours(0, 0, 0, 0);

                res.data.forEach(e => {
                    if (!e.eventDate) return;

                    let eventDate = new Date(e.eventDate);
                    eventDate.setHours(0, 0, 0, 0);

                    if (eventDate <= today) return;

                    let dateKey = formatDate(e.eventDate);
                    if (!grouped[dateKey]) grouped[dateKey] = [];
                    grouped[dateKey].push(e);
                });

                let html = '';

                // for (let date in grouped) {
                //     html += `<div class="event-section">
                //                 <h4>${date}</h4>
                //                 <div class="event-row">`;

                //     grouped[date].forEach(ev => {
                //         html += `<div class="event-card">
                //                     <img src="${ev.brochureImagePath || 'https:via.placeholder.com/100'}">
                //                     <h5>${ev.eventName}</h5>
                //                     <p>${ev.organisedBy || ''}</p>
                //                     <button class="btn-view" onclick='showDetails(${JSON.stringify(ev)})'>
                //                         View Details
                //                     </button>
                //                  </div>`;
                //     });

                //     html += `</div></div>`;
                // }
                for (let date in grouped) {
                    let events = grouped[date];
                    let containerClass = events.length > 5 ? 'event-scroll' : 'event-row';

                    html += `<div class="event-section">
                                <h4>${date}</h4>
                                <div class="${containerClass}">`;

                    events.forEach(ev => {
                        html += `<div class="event-card">
                                    <img src="${ev.brochureImagePath || 'https://via.placeholder.com/100'}">
                                    <h5>${ev.eventName}</h5>
                                    <p>${ev.organisedBy || ''}</p>
                                    <button class="btn-view"
                                            onclick='showDetails(${JSON.stringify(ev)})'>
                                        View Details
                                    </button>
                                 </div>`;
                    });

                    html += `</div></div>`;
                }
                $('#eventsContainer').html(html || '<p>No upcoming events</p>');
            });
        }

        window.showDetails = function (ev) {
            $('#eventDetailsTitle').text(ev.eventName);
            $('#eventDetailsDate').text(formatDate(ev.eventDate));
            $('#eventDetailsDeadline').text(formatDate(ev.registrationDeadline));
            $('#eventDetailsContact').text(ev.contactNumber || '');
            $('#eventDetailsDescription').text(ev.description || '');
            $('#eventDetailsBrochure').html(
                ev.brochureImagePath
                    ? `<a href="${ev.brochureImagePath}" target="_blank">📄 View Brochure</a>`
                    : ''
            );
            $('#eventDetailsModal').modal('show');
        }

        function formatDate(dateStr) {
            if (!dateStr) return '';
            let d = new Date(dateStr);
            return d.toLocaleDateString();
        }
    </script>
}
