@{
    ViewData["Title"] = "Event Details";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .event-container {
        max-width: 1200px;
        margin: 40px auto;
        padding: 30px;
    }

    /* Header */
    .event-header {
        text-align: center;
        margin-bottom: 20px;
        color: white;
    }

        .event-header h1 {
            font-size: 3rem;
            font-weight: bold;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .event-header p {
            font-size: 1.2rem;
            opacity: 0.9;
        }

    /* Search / Controls */
    .event-controls {
        display: flex;
        gap: 12px;
        align-items: center;
        justify-content: space-between;
        margin: 20px 0 30px 0;
    }

    .search-box {
        flex: 1;
        max-width: 520px;
        display: flex;
        gap: 8px;
    }

    .search-box input {
        width: 100%;
        padding: 10px 14px;
        border-radius: 8px;
        border: none;
        outline: none;
        font-size: 1rem;
    }

    .search-box .btn {
        padding: 10px 14px;
        border-radius: 8px;
    }

    /* Date Section */
    .event-date-section {
        margin-bottom: 40px;
    }

        .event-date-section h3 {
            color: white;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.3);
            padding-bottom: 5px;
        }

    /* Horizontal scroll container */
    .event-row {
        display: flex;
        gap: 20px;
        overflow-x: auto;
        padding-bottom: 10px;
    }

        .event-row::-webkit-scrollbar {
            height: 8px;
        }

        .event-row::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.3);
            border-radius: 4px;
        }

    /* Card */
    .event-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        width: 260px;
        height: 360px;
        display: flex;
        flex-direction: column;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        flex-shrink: 0; /* Prevent shrinking in horizontal scroll */
    }

        .event-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
        }

        .event-card h5 {
            font-weight: 700;
            color: #333;
            margin-bottom: 10px;
        }

        .event-card p {
            font-size: 0.9rem;
            color: #666;
            margin-bottom: 6px;
        }

    .card-actions {
        margin-top: auto;
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    .btn-view, .btn-download {
        padding: 8px 12px;
        border-radius: 50px;
        font-weight: 600;
        border: none;
        text-decoration: none;
        display: inline-block;
    }

    .btn-view {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .btn-download {
        background: #f1f1f1;
        color: #333;
        border: 1px solid rgba(0,0,0,0.06);
    }

    .btn-view:hover {
        transform: scale(1.03);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .no-events {
        color: white;
        text-align: center;
        font-size: 1.2rem;
    }
</style>

<div class="event-container">
    <div class="event-header">
        <h1>📅 Event Details</h1>
        <p>Explore upcoming college events</p>
    </div>

    <div class="event-controls">
        <div class="search-box">
            <input id="clubSearch" type="text" placeholder="Search by club (e.g., Photography Club, Coding Club)..." />
            <button id="clearSearch" class="btn btn-light">Clear</button>
        </div>

        <!-- Optional: a client-side download-all button could be implemented if you provide a server endpoint.
             For now we keep only per-event download buttons below. -->
    </div>

    <div id="eventGrid">
        <!-- Events loaded here by JS -->
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

    <script>
        // Keep a global reference to all upcoming events so we can re-render on client-side filter
        let allUpcomingEvents = [];

        $(document).ready(function () {
            loadEvents();

            // Search input behavior: filter by organisedBy (club) case-insensitive
            $("#clubSearch").on("input", function () {
                const q = $(this).val().trim().toLowerCase();
                renderEvents(filterByClub(allUpcomingEvents, q));
            });

            $("#clearSearch").on("click", function () {
                $("#clubSearch").val('');
                renderEvents(allUpcomingEvents);
            });
        });

        function loadEvents() {
            $.ajax({
                url: '@Url.Action("GetAllEvents", "Website")',
                type: 'GET',
                success: function (res) {
                    let dataArray = res && (res.data || res);

                    if (!Array.isArray(dataArray) || dataArray.length === 0) {
                        $("#eventGrid").html('<div class="no-events">No events found</div>');
                        return;
                    }

                    // Filter upcoming events only
                    const today = new Date();
                    dataArray = dataArray.filter(e => {
                        // defensively handle missing date
                        try {
                            return new Date(e.eventDate) >= today;
                        } catch {
                            return false;
                        }
                    });

                    // store globally for client-side filtering
                    allUpcomingEvents = dataArray;

                    // initial render (no filter)
                    renderEvents(allUpcomingEvents);
                },
                error: function (xhr) {
                    console.error("Error loading events", xhr.responseText);
                    alert("Failed to load events");
                }
            });
        }

        function filterByClub(events, query) {
            if (!query) return events;

            return events.filter(e => {
                const club = (e.organisedBy || '').toString().toLowerCase();
                const name = (e.eventName || '').toString().toLowerCase();
                // match club name or event name
                return club.includes(query) || name.includes(query);
            });
        }

        function renderEvents(events) {
            if (!Array.isArray(events) || events.length === 0) {
                $("#eventGrid").html('<div class="no-events">No events match your search</div>');
                return;
            }

            // Group events by date
            const grouped = {};
            events.forEach(e => {
                const dateKey = formatDate(e.eventDate);
                if (!grouped[dateKey]) grouped[dateKey] = [];
                grouped[dateKey].push(e);
            });

            let html = '';

            for (const [date, evs] of Object.entries(grouped)) {
                html += `
                    <div class="event-date-section">
                        <h3>${date}</h3>
                        <div class="event-row">
                            ${evs.map(e => {
                                // safe values
                                const brochure = e.brochureImagePath || '';
                                const hasBrochure = brochure.length > 0;
                                // If you want the download file name to be meaningful, you can construct a filename here:
                                const downloadAttr = hasBrochure ? `download="${(e.eventName || 'brochure').replace(/[^a-z0-9_.-]/gi,'_')}.pdf"` : '';
                                const viewBtn = hasBrochure ? `<a href="${brochure}" target="_blank" class="btn-view">View Brochure</a>` : '';
                                const downloadBtn = hasBrochure ? `<a href="${brochure}" ${downloadAttr} class="btn-download">Download</a>` : '';
                                return `
                                    <div class="event-card">
                                        <h5>${e.eventName ?? ''}</h5>
                                        <p><strong>Organised By:</strong> ${e.organisedBy ?? ''}</p>
                                        <p><strong>Registration Till:</strong> ${formatDate(e.registrationDeadline)}</p>
                                        <p><strong>Contact:</strong> ${e.contactNumber ?? ''}</p>
                                        <p style="min-height:48px; overflow:hidden; text-overflow:ellipsis;">${e.description ?? ''}</p>
                                        <div class="card-actions">
                                            ${viewBtn}
                                            ${downloadBtn}
                                        </div>
                                    </div>
                                `;
                            }).join('')}
                        </div>
                    </div>
                `;
            }

            $("#eventGrid").html(html);
        }

        function formatDate(dateStr) {
            if (!dateStr) return '';
            const options = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };
            return new Date(dateStr).toLocaleDateString(undefined, options);
        }
    </script>
}