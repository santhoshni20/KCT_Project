@{
    Layout = "_Layout";
    ViewData["Title"] = "Event Details";
}

<h4 class="fw-bold mb-3">Event Details</h4>

<div class="card">
    <div class="table-responsive">
        <table class="table table-bordered" id="eventsTable">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Event Name</th>
                    <th>Organised By</th>
                    <th>Event Date</th>
                    <th>Registration Deadline</th>
                    <th>Contact</th>
                    <th>Description</th>
                    <th>Brochure</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            loadEvents();
        });

        function loadEvents() {
            $.ajax({
                url: '@Url.Action("GetAllEvents", "Website")',
                type: 'GET',
                success: function (res) {
                    let rows = "";

                    if (res.data && res.data.length > 0) {
                        res.data.forEach((e, i) => {
                            rows += `
                            <tr>
                                <td>${i + 1}</td>
                                <td>${e.eventName}</td>
                                <td>${e.organisedBy}</td>
                                <td>${formatDate(e.eventDate)}</td>
                                <td>${formatDate(e.registrationDeadline)}</td>
                                <td>${e.contactNumber ?? ''}</td>
                                <td>${e.description ?? ''}</td>
                                <td>
                                    ${e.brochureImagePath
                                        ? `<a href="${e.brochureImagePath}" target="_blank">View</a>`
                                        : ''}
                                </td>
                            </tr>`;
                        });
                    } else {
                        rows = `<tr>
                                    <td colspan="8" class="text-center">No events found</td>
                                </tr>`;
                    }

                    $("#eventsTable tbody").html(rows);
                },
                error: function () {
                    alert("Failed to load events");
                }
            });
        }

        function formatDate(dateStr) {
            if (!dateStr) return '';
            return new Date(dateStr).toLocaleDateString();
        }
    </script>
}
