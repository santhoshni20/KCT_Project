@{
    ViewData["Title"] = "Hall Locator";
    Layout = "~/Views/Shared/_LayoutWebsite.cshtml";
}

<style>
    .hall-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }

    .header-section {
        background: var(--bg-elevated);
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 30px;
        border: 1px solid var(--border-subtle);
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--text-main);
    }

    .page-subtitle {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 24px;
    }

    /* Search Box */
    .search-section {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
    }

    .search-input {
        flex: 1;
        padding: 14px 18px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        color: var(--text-main);
        font-size: 0.95rem;
    }

        .search-input::placeholder {
            color: var(--text-muted);
        }

        .search-input:focus {
            outline: none;
            border-color: #3b82f6;
            background: rgba(255,255,255,0.08);
        }

    .search-btn {
        padding: 14px 28px;
        background: #3b82f6;
        border: none;
        border-radius: 8px;
        color: white;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

        .search-btn:hover {
            background: #2563eb;
            transform: translateY(-1px);
        }

    /* Filter Tabs */
    .filter-section {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 10px 20px;
        background: transparent;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        color: var(--text-main);
        cursor: pointer;
        transition: all 0.3s;
        font-size: 0.9rem;
        font-weight: 500;
    }

        .filter-btn:hover {
            background: rgba(255,255,255,0.05);
        }

        .filter-btn.active {
            background: rgba(59, 130, 246, 0.2);
            border-color: #3b82f6;
            color: #60a5fa;
        }

    /* Alert Box */
    .alert-box {
        padding: 14px 18px;
        border-radius: 8px;
        margin-bottom: 20px;
        display: none;
        font-size: 0.95rem;
    }

    .alert-success {
        background: rgba(34, 197, 94, 0.15);
        border: 1px solid #22c55e;
        color: #4ade80;
    }

    .alert-error {
        background: rgba(239, 68, 68, 0.15);
        border: 1px solid #ef4444;
        color: #f87171;
    }

    /* Search Result Card */
    .result-card {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(147, 51, 234, 0.15));
        border: 2px solid #3b82f6;
        border-radius: 12px;
        padding: 28px;
        margin-bottom: 24px;
        display: none;
    }

        .result-card h3 {
            color: #60a5fa;
            margin-bottom: 20px;
            font-size: 1.4rem;
            font-weight: 700;
        }

        .result-card .result-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }

        .result-card .result-item {
            display: flex;
            flex-direction: column;
        }

        .result-card .result-label {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .result-card .result-value {
            color: var(--text-main);
            font-size: 1.3rem;
            font-weight: 700;
        }

    /* Hall Cards */
    .halls-section {
        margin-top: 30px;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 20px;
        color: var(--text-main);
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .section-title .count-badge {
            background: rgba(59, 130, 246, 0.2);
            color: #60a5fa;
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 0.9rem;
        }

    .hall-card {
        background: var(--bg-elevated);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
        transition: all 0.3s;
    }

        .hall-card:hover {
            border-color: #3b82f6;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }

    .hall-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .hall-title-group h3 {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 6px;
    }

    .hall-meta {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        font-size: 0.9rem;
        color: var(--text-muted);
    }

        .hall-meta span {
            display: flex;
            align-items: center;
            gap: 6px;
        }

    .dept-badge {
        padding: 8px 16px;
        background: rgba(59, 130, 246, 0.2);
        border: 1px solid #3b82f6;
        border-radius: 8px;
        color: #60a5fa;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .exam-badge {
        padding: 6px 12px;
        background: rgba(251, 191, 36, 0.2);
        border: 1px solid #fbbf24;
        border-radius: 6px;
        color: #fcd34d;
        font-size: 0.85rem;
        font-weight: 500;
    }

    /* Students Table */
    .students-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 16px;
    }

        .students-table thead {
            background: rgba(255,255,255,0.05);
        }

        .students-table th {
            padding: 12px;
            text-align: left;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .students-table td {
            padding: 12px;
            border-top: 1px solid rgba(255,255,255,0.05);
            color: var(--text-main);
        }

        .students-table tbody tr:hover {
            background: rgba(255,255,255,0.03);
        }

    .roll-number {
        font-family: 'Courier New', monospace;
        font-weight: 600;
        color: #60a5fa;
    }

    .desk-seat {
        display: flex;
        gap: 16px;
    }

    .desk-seat-item {
        padding: 4px 10px;
        background: rgba(255,255,255,0.05);
        border-radius: 4px;
        font-size: 0.85rem;
    }

    /* Loading & Empty States */
    .loading-spinner {
        text-align: center;
        padding: 60px 20px;
        display: none;
    }

        .loading-spinner .spinner {
            font-size: 3rem;
            animation: spin 1s linear infinite;
        }

    @@keyframes spin {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: var(--text-muted);
    }

        .empty-state .icon {
            font-size: 4rem;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .empty-state h3 {
            font-size: 1.4rem;
            margin-bottom: 12px;
            color: var(--text-main);
        }

        .empty-state p {
            font-size: 1rem;
        }
</style>

<div class="hall-container">
    <!-- Header Section -->
    <div class="header-section">
        <h1 class="page-title">🗺️ Hall Locator</h1>
        <p class="page-subtitle">Find your exam hall allocation by roll number or browse by department</p>

        <!-- Search by Roll Number -->
        <div class="search-section">
            <input type="text"
                   id="rollNumberInput"
                   class="search-input"
                   placeholder="Enter your roll number (e.g., 23bit001, 23cse025)" />
            <button class="search-btn" onclick="searchByRollNumber()">
                🔍 Search
            </button>
        </div>

        <!-- Alert Box -->
        <div id="alertBox" class="alert-box"></div>

        <!-- Search Result -->
        <div id="searchResult" class="result-card">
            <h3>✓ Your Hall Allocation</h3>
            <div class="result-grid">
                <div class="result-item">
                    <span class="result-label">Roll Number</span>
                    <span class="result-value" id="resultRoll"></span>
                </div>
                <div class="result-item">
                    <span class="result-label">Department</span>
                    <span class="result-value" id="resultDept"></span>
                </div>
                <div class="result-item">
                    <span class="result-label">Hall</span>
                    <span class="result-value" id="resultHall"></span>
                </div>
                <div class="result-item">
                    <span class="result-label">Block</span>
                    <span class="result-value" id="resultBlock"></span>
                </div>
                <div class="result-item">
                    <span class="result-label">Desk No.</span>
                    <span class="result-value" id="resultDesk"></span>
                </div>
                <div class="result-item">
                    <span class="result-label">Seat No.</span>
                    <span class="result-value" id="resultSeat"></span>
                </div>
                <div class="result-item">
                    <span class="result-label">Exam Date</span>
                    <span class="result-value" id="resultDate"></span>
                </div>
                <div class="result-item">
                    <span class="result-label">Exam Name</span>
                    <span class="result-value" id="resultExam"></span>
                </div>
            </div>
        </div>

        <!-- Department Filters -->
        <div class="filter-section">
            <button class="filter-btn active" onclick="filterByDept('')">All Departments</button>
            <button class="filter-btn" onclick="filterByDept('IT')">IT</button>
            <button class="filter-btn" onclick="filterByDept('CSE')">CSE</button>
            <button class="filter-btn" onclick="filterByDept('AIDS')">AIDS</button>
        </div>
    </div>

    <!-- Halls Section -->
    <div class="halls-section">
        <h2 class="section-title">
            📋 Hall Allocations
            <span class="count-badge" id="hallCount">0 halls</span>
        </h2>

        <!-- Loading Spinner -->
        <div id="loadingSpinner" class="loading-spinner">
            <div class="spinner">⏳</div>
            <p>Loading hall allocations...</p>
        </div>

        <!-- Halls Container -->
        <div id="hallsContainer"></div>

        <!-- Empty State -->
        <div id="emptyState" class="empty-state" style="display:none;">
            <div class="icon">📭</div>
            <h3>No Allocations Found</h3>
            <p>No student allocations found for the selected department.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentDepartment = '';

        // Load allocations on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadHallAllocations('');
        });

        // Search by Roll Number
        function searchByRollNumber() {
            const rollNumber = document.getElementById('rollNumberInput').value.trim();
            const alertBox = document.getElementById('alertBox');
            const resultBox = document.getElementById('searchResult');

            if (!rollNumber) {
                showAlert('Please enter a roll number', 'error');
                return;
            }

            resultBox.style.display = 'none';
            alertBox.style.display = 'none';

            fetch(`/Website/SearchHallByRollNumber?rollNumber=${encodeURIComponent(rollNumber)}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById('resultRoll').textContent = data.data.rollNumber;
                        document.getElementById('resultDept').textContent = data.data.department;
                        document.getElementById('resultBlock').textContent = data.data.blockName;
                        document.getElementById('resultHall').textContent = data.data.roomNumber;
                        document.getElementById('resultDesk').textContent = data.data.deskNumber;
                        document.getElementById('resultSeat').textContent = data.data.seatNumber;
                        document.getElementById('resultDate').textContent = formatDate(data.data.examDate);
                        document.getElementById('resultExam').textContent = data.data.examName || 'N/A';

                        resultBox.style.display = 'block';

                        // Scroll to result
                        resultBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    } else {
                        showAlert(data.message, 'error');
                    }
                })
                .catch(err => {
                    showAlert('Error searching. Please try again.', 'error');
                    console.error(err);
                });
        }

        // Filter by Department
        function filterByDept(dept) {
            currentDepartment = dept;

            // Update active button
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');

            loadHallAllocations(dept);
        }

        // Load Hall Allocations
        function loadHallAllocations(department) {
            const container = document.getElementById('hallsContainer');
            const spinner = document.getElementById('loadingSpinner');
            const emptyState = document.getElementById('emptyState');
            const countBadge = document.getElementById('hallCount');

            // Show loading
            container.innerHTML = '';
            emptyState.style.display = 'none';
            spinner.style.display = 'block';

            const url = department
                ? `/Website/GetAllHallAllocations?department=${encodeURIComponent(department)}`
                : '/Website/GetAllHallAllocations';

            fetch(url)
                .then(res => res.json())
                .then(response => {
                    spinner.style.display = 'none';

                    if (!response.success || !response.data || response.data.length === 0) {
                        emptyState.style.display = 'block';
                        countBadge.textContent = '0 halls';
                        return;
                    }

                    const halls = response.data;
                    countBadge.textContent = `${halls.length} hall${halls.length !== 1 ? 's' : ''}`;

                    container.innerHTML = halls.map(hall => renderHallCard(hall)).join('');
                })
                .catch(err => {
                    spinner.style.display = 'none';
                    showAlert('Error loading hall allocations', 'error');
                    console.error(err);
                });
        }

        // Render Hall Card
        function renderHallCard(hall) {
            const dateStr = formatDate(hall.examDate);

            return `
                <div class="hall-card">
                    <div class="hall-header">
                        <div class="hall-title-group">
                            <h3>${hall.roomNumber}</h3>
                            <div class="hall-meta">
                                <span>📍 ${hall.blockName}</span>
                                <span>📅 ${dateStr}</span>
                                <span>👥 ${hall.occupiedSeats} / ${hall.totalSeats} seats</span>
                            </div>
                        </div>
                        <div>
                            <div class="dept-badge">${hall.department}</div>
                            ${hall.examName ? `<div class="exam-badge" style="margin-top:8px;">${hall.examName}</div>` : ''}
                        </div>
                    </div>

                    <table class="students-table">
                        <thead>
                            <tr>
                                <th style="width:50px;">#</th>
                                <th>Roll Number</th>
                                <th>Desk Number</th>
                                <th>Seat Number</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${hall.students.map((student, index) => `
                                <tr>
                                    <td>${index + 1}</td>
                                    <td><span class="roll-number">${student.rollNumber}</span></td>
                                    <td><span class="desk-seat-item">Desk ${student.deskNumber}</span></td>
                                    <td><span class="desk-seat-item">Seat ${student.seatNumber}</span></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            `;
        }

        // Show Alert
        function showAlert(message, type) {
            const alertBox = document.getElementById('alertBox');
            alertBox.className = `alert-box alert-${type}`;
            alertBox.textContent = message;
            alertBox.style.display = 'block';

            setTimeout(() => {
                alertBox.style.display = 'none';
            }, 5000);
        }

        // Format Date
        function formatDate(dateStr) {
            const date = new Date(dateStr);
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            const examDate = new Date(date);
            examDate.setHours(0, 0, 0, 0);

            const daysDiff = Math.floor((examDate - today) / (1000 * 60 * 60 * 24));

            if (daysDiff === 0) return 'TODAY';
            if (daysDiff === 1) return 'TOMORROW';

            return date.toLocaleDateString('en-GB', {
                day: '2-digit',
                month: 'short',
                year: 'numeric'
            });
        }

        // Enter key to search
        document.getElementById('rollNumberInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchByRollNumber();
            }
        });
    </script>
}