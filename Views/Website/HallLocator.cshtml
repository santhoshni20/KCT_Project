@model List<ksi.Models.DTO.PublicHallListDTO>
@{
    ViewData["Title"] = "Hall Locator";
    Layout = "~/Views/Shared/_LayoutWebsite.cshtml";
}

<style>
    .hall-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .search-card {
        background: var(--bg-elevated);
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 30px;
        border: 1px solid var(--border-subtle);
    }

    .search-title {
        font-size: 1.5rem;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-main);
    }

    .search-subtitle {
        color: var(--text-muted);
        margin-bottom: 24px;
        font-size: 0.95rem;
    }

    .filter-tabs {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .filter-tab {
        padding: 10px 20px;
        background: transparent;
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px;
        color: var(--text-main);
        cursor: pointer;
        transition: all 0.3s;
        font-size: 0.95rem;
    }

        .filter-tab:hover {
            background: rgba(255,255,255,0.05);
        }

        .filter-tab.active {
            background: rgba(59, 130, 246, 0.2);
            border-color: #3b82f6;
            color: #60a5fa;
        }

    .search-box {
        display: flex;
        gap: 12px;
        margin-bottom: 20px;
    }

        .search-box input {
            flex: 1;
            padding: 12px 16px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 8px;
            color: var(--text-main);
            font-size: 0.95rem;
        }

            .search-box input::placeholder {
                color: var(--text-muted);
            }

            .search-box input:focus {
                outline: none;
                border-color: #3b82f6;
                background: rgba(255,255,255,0.08);
            }

        .search-box button {
            padding: 12px 24px;
            background: #3b82f6;
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.3s;
        }

            .search-box button:hover {
                background: #2563eb;
            }

    .result-card {
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid #3b82f6;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 20px;
    }

        .result-card h3 {
            color: #60a5fa;
            margin-bottom: 16px;
            font-size: 1.2rem;
        }

        .result-card .info-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 12px;
        }

        .result-card .info-item {
            display: flex;
            flex-direction: column;
        }

        .result-card .info-label {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-bottom: 4px;
        }

        .result-card .info-value {
            color: var(--text-main);
            font-size: 1.1rem;
            font-weight: 600;
        }

    .halls-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
    }

    .hall-card {
        background: var(--bg-elevated);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        padding: 20px;
        transition: all 0.3s;
    }

        .hall-card:hover {
            border-color: #3b82f6;
            transform: translateY(-2px);
        }

        .hall-card .hall-header {
            display: flex;
            justify-content: space-between;
            align-items: start;
            margin-bottom: 16px;
        }

        .hall-card .hall-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text-main);
        }

        .hall-card .hall-block {
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .hall-card .hall-info {
            margin-bottom: 12px;
        }

        .hall-card .info-line {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

    .info-line:last-child {
        border-bottom: none;
    }

    .info-line .label {
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    .info-line .value {
        color: var(--text-main);
        font-weight: 500;
    }

    .hall-card .exam-badge {
        display: inline-block;
        padding: 6px 12px;
        background: rgba(59, 130, 246, 0.2);
        border: 1px solid #3b82f6;
        border-radius: 6px;
        color: #60a5fa;
        font-size: 0.85rem;
        font-weight: 500;
        margin-top: 12px;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-muted);
    }

        .empty-state svg {
            width: 80px;
            height: 80px;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .empty-state h3 {
            font-size: 1.3rem;
            margin-bottom: 8px;
            color: var(--text-main);
        }

        .empty-state p {
            font-size: 0.95rem;
        }

    .alert-box {
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
        display: none;
    }

    .alert-success {
        background: rgba(34, 197, 94, 0.1);
        border: 1px solid #22c55e;
        color: #4ade80;
    }

    .alert-error {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid #ef4444;
        color: #f87171;
    }
</style>

<div class="hall-container">
    <!-- Search Section -->
    <div class="search-card">
        <h1 class="search-title">🗺️ Hall Locator</h1>
        <p class="search-subtitle">Find your exam hall allocation by roll number or browse by department</p>

        <!-- Search by Roll Number -->
        <div class="search-box">
            <input type="text"
                   id="rollNumberInput"
                   placeholder="Enter your roll number (e.g., 23bit001)" />
            <button onclick="searchByRollNumber()">Search</button>
        </div>

        <!-- Alert Box -->
        <div id="alertBox" class="alert-box"></div>

        <!-- Search Result -->
        <div id="searchResult" style="display:none;" class="result-card">
            <h3>✓ Hall Allocation Found</h3>
            <div class="info-row">
                <div class="info-item">
                    <span class="info-label">Roll Number</span>
                    <span class="info-value" id="resultRoll"></span>
                </div>
                <div class="info-item">
                    <span class="info-label">Department</span>
                    <span class="info-value" id="resultDept"></span>
                </div>
                <div class="info-item">
                    <span class="info-label">Block</span>
                    <span class="info-value" id="resultBlock"></span>
                </div>
                <div class="info-item">
                    <span class="info-label">Hall</span>
                    <span class="info-value" id="resultHall"></span>
                </div>
            </div>
            <div class="info-row">
                <div class="info-item">
                    <span class="info-label">Desk Number</span>
                    <span class="info-value" id="resultDesk"></span>
                </div>
                <div class="info-item">
                    <span class="info-label">Seat Number</span>
                    <span class="info-value" id="resultSeat"></span>
                </div>
                <div class="info-item">
                    <span class="info-label">Exam Date</span>
                    <span class="info-value" id="resultDate"></span>
                </div>
                <div class="info-item">
                    <span class="info-label">Exam Name</span>
                    <span class="info-value" id="resultExam"></span>
                </div>
            </div>
        </div>

        <!-- Department Filters -->
        <div class="filter-tabs">
            <button class="filter-tab active" onclick="filterByDept('all')">All Halls</button>
            <button class="filter-tab" onclick="filterByDept('IT')">IT</button>
            <button class="filter-tab" onclick="filterByDept('CSE')">CSE</button>
            <button class="filter-tab" onclick="filterByDept('AIDS')">AIDS</button>
        </div>
    </div>

    <!-- Halls Grid -->
    <div id="hallsGrid" class="halls-grid">
        @if (Model != null && Model.Count > 0)
        {
            foreach (var hall in Model)
            {
                var daysDiff = (hall.examDate - DateTime.Today).Days;
                var dateText = daysDiff == 0 ? "TODAY" : daysDiff == 1 ? "TOMORROW" : hall.examDate.ToString("dd MMM yyyy");

                <div class="hall-card" data-dept="all">
                    <div class="hall-header">
                        <div>
                            <div class="hall-title">@hall.roomNumber</div>
                            <div class="hall-block">@hall.blockName</div>
                        </div>
                    </div>

                    <div class="hall-info">
                        <div class="info-line">
                            <span class="label">Exam Date</span>
                            <span class="value">@dateText</span>
                        </div>
                        <div class="info-line">
                            <span class="label">Total Seats</span>
                            <span class="value">@hall.totalSeats</span>
                        </div>
                        <div class="info-line">
                            <span class="label">Occupied</span>
                            <span class="value">@hall.occupiedSeats</span>
                        </div>
                        <div class="info-line">
                            <span class="label">Available</span>
                            <span class="value">@(hall.totalSeats - hall.occupiedSeats)</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(hall.examName))
                    {
                        <div class="exam-badge">@hall.examName</div>
                    }
                </div>
            }
        }
        else
        {
            <div class="empty-state" style="grid-column: 1/-1;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <h3>No Upcoming Exams</h3>
                <p>There are no exam halls scheduled at the moment.</p>
            </div>
        }
    </div>

    <!-- Loading for department filter -->
    <div id="loadingSpinner" style="display:none; text-align:center; padding:40px; color:var(--text-muted);">
        <div style="font-size:2rem; margin-bottom:16px;">⏳</div>
        <div>Loading halls...</div>
    </div>
</div>

@section Scripts {
    <script>
        let allHalls = @Html.Raw(Json.Serialize(Model));

        function searchByRollNumber() {
            const rollNumber = document.getElementById('rollNumberInput').value.trim();
            const alertBox = document.getElementById('alertBox');
            const resultBox = document.getElementById('searchResult');

            if (!rollNumber) {
                showAlert('Please enter a roll number', 'error');
                return;
            }

            // Hide previous results
            resultBox.style.display = 'none';
            alertBox.style.display = 'none';

            fetch(`/Website/SearchHallByRollNumber?rollNumber=${encodeURIComponent(rollNumber)}`)
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        // Show result
                        document.getElementById('resultRoll').textContent = data.data.rollNumber;
                        document.getElementById('resultDept').textContent = data.data.department;
                        document.getElementById('resultBlock').textContent = data.data.blockName;
                        document.getElementById('resultHall').textContent = data.data.roomNumber;
                        document.getElementById('resultDesk').textContent = data.data.deskNumber;
                        document.getElementById('resultSeat').textContent = data.data.seatNumber;
                        document.getElementById('resultDate').textContent = new Date(data.data.examDate).toLocaleDateString('en-GB');
                        document.getElementById('resultExam').textContent = data.data.examName || 'N/A';

                        resultBox.style.display = 'block';
                    } else {
                        showAlert(data.message, 'error');
                    }
                })
                .catch(err => {
                    showAlert('Error searching. Please try again.', 'error');
                });
        }

        function filterByDept(dept) {
            // Update active tab
            document.querySelectorAll('.filter-tab').forEach(tab => {
                tab.classList.remove('active');
            });
            event.target.classList.add('active');

            const grid = document.getElementById('hallsGrid');
            const spinner = document.getElementById('loadingSpinner');

            if (dept === 'all') {
                // Show all halls from initial load
                renderHalls(allHalls);
                return;
            }

            // Show loading
            grid.style.display = 'none';
            spinner.style.display = 'block';

            fetch(`/Website/HallLocatorByDepartment?department=${dept}`)
                .then(res => res.json())
                .then(halls => {
                    spinner.style.display = 'none';
                    grid.style.display = 'grid';
                    renderHalls(halls);
                })
                .catch(err => {
                    spinner.style.display = 'none';
                    grid.style.display = 'grid';
                    showAlert('Error loading halls', 'error');
                });
        }

        function renderHalls(halls) {
            const grid = document.getElementById('hallsGrid');

            if (!halls || halls.length === 0) {
                grid.innerHTML = `
                    <div class="empty-state" style="grid-column: 1/-1;">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                        <h3>No Halls Found</h3>
                        <p>No exam halls found for this department.</p>
                    </div>
                `;
                return;
            }

            grid.innerHTML = halls.map(hall => {
                const examDate = new Date(hall.examDate);
                const today = new Date();
                const daysDiff = Math.floor((examDate - today) / (1000 * 60 * 60 * 24));
                const dateText = daysDiff === 0 ? 'TODAY' : daysDiff === 1 ? 'TOMORROW' : examDate.toLocaleDateString('en-GB');

                return `
                    <div class="hall-card">
                        <div class="hall-header">
                            <div>
                                <div class="hall-title">${hall.roomNumber}</div>
                                <div class="hall-block">${hall.blockName}</div>
                            </div>
                        </div>
                        <div class="hall-info">
                            <div class="info-line">
                                <span class="label">Exam Date</span>
                                <span class="value">${dateText}</span>
                            </div>
                            <div class="info-line">
                                <span class="label">Total Seats</span>
                                <span class="value">${hall.totalSeats}</span>
                            </div>
                            <div class="info-line">
                                <span class="label">Occupied</span>
                                <span class="value">${hall.occupiedSeats}</span>
                            </div>
                            <div class="info-line">
                                <span class="label">Available</span>
                                <span class="value">${hall.totalSeats - hall.occupiedSeats}</span>
                            </div>
                        </div>
                        ${hall.examName ? `<div class="exam-badge">${hall.examName}</div>` : ''}
                    </div>
                `;
            }).join('');
        }

        function showAlert(message, type) {
            const alertBox = document.getElementById('alertBox');
            alertBox.className = `alert-box alert-${type}`;
            alertBox.textContent = message;
            alertBox.style.display = 'block';

            setTimeout(() => {
                alertBox.style.display = 'none';
            }, 5000);
        }

        // Allow Enter key to search
        document.getElementById('rollNumberInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                searchByRollNumber();
            }
        });
    </script>
}