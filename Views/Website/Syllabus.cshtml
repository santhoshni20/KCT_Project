@{
    ViewData["Title"] = "Syllabus";
}

<!-- Font Awesome & Bootstrap -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<style>
    .syllabus-container {
        background: linear-gradient(135deg, #007bff, #6610f2);
        color: #fff;
        font-family: "Poppins", sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        padding: 40px 0;
    }

    .page-container {
        background: #ffffff;
        color: #333;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        padding: 40px 50px;
        text-align: center;
        width: 90%;
        max-width: 550px;
        animation: fadeIn 0.8s ease-in-out;
    }

        .page-container h2 {
            font-weight: 700;
            margin-bottom: 25px;
            color: #0d6efd;
        }

    .batch-section {
        margin-bottom: 25px;
        text-align: left;
    }

    .batch-label {
        font-size: 1rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: block;
    }

    .form-select {
        border-radius: 10px;
        padding: 10px;
        box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .form-select:focus {
            transform: scale(1.03);
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.3);
        }

    .download-btn {
        font-size: 1.1rem;
        font-weight: 600;
        background: linear-gradient(90deg, #007bff, #6610f2);
        color: white;
        padding: 12px 25px;
        border-radius: 12px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: transform 0.2s, box-shadow 0.2s, background 0.3s;
    }

        .download-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 15px rgba(0, 123, 255, 0.4);
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    footer {
        margin-top: 20px;
        font-size: 0.85rem;
        color: rgba(0, 0, 0, 0.6);
    }
</style>

<div class="syllabus-container">
    <div class="page-container">
        <h2><i class="fas fa-book-open"></i> Syllabus Portal</h2>

        <!-- Batch Dropdown -->
        <div class="batch-section">
            <label class="batch-label"><i class="fas fa-users"></i> Select Batch</label>
            <select class="form-select" id="batchDropdown">
                <option value="">-- Select Batch --</option>
            </select>
        </div>

        <!-- Department Dropdown -->
        <div class="batch-section">
            <label class="batch-label"><i class="fas fa-building"></i> Select Department</label>
            <select class="form-select" id="deptDropdown" disabled>
                <option value="">-- Select Department --</option>
            </select>
        </div>

        <!-- Download Button -->
        <button class="download-btn" id="downloadBtn">
            <i class="fas fa-download"></i> Download Syllabus
        </button>

        <footer>
            <p>© 2025 KCT Syllabus Portal | Powered by ASP.NET Core</p>
        </footer>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Controller is Website (actions defined in WebsiteController)
            loadDropdown("@Url.Action("getBatches", "Website")", "batchDropdown");
            loadDropdown("@Url.Action("getDepartments", "Website")", "deptDropdown", true);
        });

        function loadDropdown(url, dropdownId, enableOnLoad = false) {
            fetch(url, { credentials: 'same-origin' })
                .then(res => res.json())
                .then(result => {
                    if (!result) {
                        console.error('No response for', dropdownId);
                        return;
                    }

                    // ApiResponseDTO shape: { statusCode, success, message, data }
                    const data = result.data ?? result; // fallback if raw array is returned
                    if (!Array.isArray(data)) {
                        console.error('Unexpected data format for', dropdownId, data);
                        return;
                    }

                    const dropdown = document.getElementById(dropdownId);
                    // Clear existing (preserve first placeholder)
                    dropdown.options.length = 1;

                    data.forEach(item => {
                        // backend returns different shapes depending on endpoint:
                        // Timetable endpoints return { id, name }, syllabus endpoints return { batchId, batchName } or { departmentId, departmentName }
                        const value = item.id ?? item.batchId ?? item.departmentId ?? item.batchID ?? item.departmentID;
                        const text = item.name ?? item.batchName ?? item.departmentName ?? item.batchName;

                        if (value === undefined || text === undefined) {
                            // skip malformed items but log for debugging
                            console.warn('Skipping dropdown item with missing fields', item);
                            return;
                        }

                        const opt = document.createElement('option');
                        opt.value = value;
                        opt.text = text;
                        dropdown.appendChild(opt);
                    });

                    if (enableOnLoad) {
                        dropdown.disabled = false;
                    }
                })
                .catch(err => console.error('Error loading dropdown', dropdownId, err));
        }

        document.getElementById("downloadBtn").addEventListener("click", () => {
            const batchId = document.getElementById("batchDropdown").value;
            const departmentId = document.getElementById("deptDropdown").value;

            if (!batchId || !departmentId) {
                alert("Please select batch and department");
                return;
            }

            window.open(
                `/Syllabus/DownloadSyllabus?batchId=${batchId}&departmentId=${departmentId}`,
                "_blank"
            );
        });
    </script>

}