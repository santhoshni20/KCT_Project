@{
    ViewData["Title"] = "Syllabus";
}

<!-- Font Awesome & Bootstrap -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<style>
    .syllabus-container {
        background: linear-gradient(135deg, #007bff, #6610f2);
        color: #fff;
        font-family: "Poppins", sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        padding: 40px 0;
    }

    .page-container {
        background: #ffffff;
        color: #333;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        padding: 40px 50px;
        text-align: center;
        width: 90%;
        max-width: 550px;
        animation: fadeIn 0.8s ease-in-out;
    }

        .page-container h2 {
            font-weight: 700;
            margin-bottom: 25px;
            color: #0d6efd;
        }

    .batch-section {
        margin-bottom: 25px;
        text-align: left;
    }

    .batch-label {
        font-size: 1rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: block;
    }

    .form-select {
        border-radius: 10px;
        padding: 10px;
        box-shadow: 0 3px 6px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .form-select:focus {
            transform: scale(1.03);
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.3);
        }

    .download-btn {
        font-size: 1.1rem;
        font-weight: 600;
        background: linear-gradient(90deg, #007bff, #6610f2);
        color: white;
        padding: 12px 25px;
        border-radius: 12px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: transform 0.2s, box-shadow 0.2s, background 0.3s;
        cursor: pointer;
    }

        .download-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 15px rgba(0, 123, 255, 0.4);
        }

        .download-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    footer {
        margin-top: 20px;
        font-size: 0.85rem;
        color: rgba(0, 0, 0, 0.6);
    }

    .loading-spinner {
        display: none;
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="syllabus-container">
    <div class="page-container">
        <h2><i class="fas fa-book-open"></i> Syllabus Portal</h2>

        <!-- Batch Dropdown -->
        <div class="batch-section">
            <label class="batch-label"><i class="fas fa-users"></i> Select Batch</label>
            <select class="form-select" id="batchDropdown">
                <option value="">-- Select Batch --</option>
            </select>
        </div>

        <!-- Department Dropdown -->
        <div class="batch-section">
            <label class="batch-label"><i class="fas fa-building"></i> Select Department</label>
            <select class="form-select" id="deptDropdown">
                <option value="">-- Select Department --</option>
            </select>
        </div>

        <!-- Download Button -->
        <button class="download-btn" id="downloadBtn">
            <i class="fas fa-download" id="downloadIcon"></i>
            <span id="downloadText">Download Syllabus</span>
            <div class="loading-spinner" id="loadingSpinner"></div>
        </button>

        <footer>
            <p>© 2025 KCT Syllabus Portal | Powered by ASP.NET Core</p>
        </footer>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Load dropdowns
            loadDropdown("@Url.Action("getBatches", "Website")", "batchDropdown");
            loadDropdown("@Url.Action("getDepartments", "Website")", "deptDropdown");

            // Add download button click handler
            const downloadBtn = document.getElementById("downloadBtn");
            if (downloadBtn) {
                downloadBtn.addEventListener("click", handleDownload);
            } else {
                console.error("Download button not found!");
            }
        });

              function loadDropdown(url, dropdownId) {
            fetch(url, { credentials: 'same-origin' })
                .then(res => {
                    if (!res.ok) {
                        throw new Error(`HTTP ${res.status}: ${res.statusText}`);
                    }
                    return res.json();
                })
                .then(result => {
                    console.log('loadDropdown result for', dropdownId, result);

                    if (!result) {
                        console.error('No response for', dropdownId);
                        return;
                    }

                    const data = result.data ?? result;
                    if (!Array.isArray(data)) {
                        console.error('Unexpected data format for', dropdownId, data);
                        return;
                    }

                    const dropdown = document.getElementById(dropdownId);
                    if (!dropdown) {
                        console.error('Dropdown not found:', dropdownId);
                        return;
                    }

                    // Keep the first "Select" option
                    dropdown.options.length = 1;

                    data.forEach(item => {
                        console.log('Processing item:', item); // Debug log

                        // Try multiple property name variations
                        let value, text;

                        if (dropdownId === 'batchDropdown') {
                            value = item.batchId ?? item.id;
                            text = item.batchName ?? item.name;
                        } else if (dropdownId === 'deptDropdown') {
                            value = item.departmentId ?? item.id;
                            text = item.departmentName ?? item.name;
                        }

                        console.log('Mapped to - value:', value, 'text:', text); // Debug log

                        if (value === undefined || text === undefined) {
                            console.warn('Skipping dropdown item with missing fields', item);
                            return;
                        }

                        const opt = document.createElement('option');
                        opt.value = value;
                        opt.text = text;
                        dropdown.appendChild(opt);
                    });

                    console.log(`${dropdownId} loaded with ${dropdown.options.length - 1} items`);
                })
                .catch(err => {
                    console.error('Error loading dropdown', dropdownId, err);
                    alert(`Failed to load ${dropdownId}. Please refresh the page.`);
                });
        }


        function handleDownload() {
            const batchId = document.getElementById("batchDropdown").value;
            const departmentId = document.getElementById("deptDropdown").value;

            console.log('Download click - batchId:', batchId, 'departmentId:', departmentId);

            if (!batchId || !departmentId) {
                alert("Please select both batch and department");
                return;
            }

            // Show loading state
            const downloadBtn = document.getElementById("downloadBtn");
            const downloadIcon = document.getElementById("downloadIcon");
            const downloadText = document.getElementById("downloadText");
            const loadingSpinner = document.getElementById("loadingSpinner");

            downloadBtn.disabled = true;
            downloadIcon.style.display = 'none';
            downloadText.textContent = 'Checking...';
            loadingSpinner.style.display = 'block';

            // Debug: Check if syllabus exists
            const debugUrl = '@Url.Action("DebugSyllabus", "Website")';
            fetch(`${debugUrl}?batchId=${encodeURIComponent(batchId)}&departmentId=${encodeURIComponent(departmentId)}`,
                { credentials: 'same-origin' })
                .then(r => {
                    if (!r.ok) {
                        throw new Error(`HTTP ${r.status}: ${r.statusText}`);
                    }
                    return r.json();
                })
                .then(debugResp => {
                    console.log('DebugSyllabus response:', debugResp);

                    if (debugResp && debugResp.count > 0) {
                        // Open download link
                        const downloadUrl = '@Url.Action("DownloadSyllabus", "Website")';
                        window.open(`${downloadUrl}?batchId=${batchId}&departmentId=${departmentId}`, "_blank");

                        // Reset button state
                        setTimeout(() => {
                            resetDownloadButton();
                        }, 1000);
                    } else {
                        alert('Syllabus not found for the selected batch and department.\n\nPlease contact your administrator to upload the syllabus.');
                        resetDownloadButton();
                    }
                })
                .catch(err => {
                    console.error('Debug call failed', err);
                    alert('Error checking syllabus availability. Please try again.');
                    resetDownloadButton();
                });
        }

        function resetDownloadButton() {
            const downloadBtn = document.getElementById("downloadBtn");
            const downloadIcon = document.getElementById("downloadIcon");
            const downloadText = document.getElementById("downloadText");
            const loadingSpinner = document.getElementById("loadingSpinner");

            downloadBtn.disabled = false;
            downloadIcon.style.display = 'inline';
            downloadText.textContent = 'Download Syllabus';
            loadingSpinner.style.display = 'none';
        }
    </script>
}
