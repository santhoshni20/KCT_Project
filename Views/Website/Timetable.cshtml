@{
    Layout = "_LayoutWebsite";
    ViewData["Title"] = "View Timetable";
}

<h4 class="fw-bold mb-3">View Timetable</h4>

<div class="card p-3 mb-4">
    <div class="row g-3">

        <div class="col-md-4">
            <label>Batch</label>
            <select id="batch" class="form-control"></select>
        </div>

        <div class="col-md-4">
            <label>Department</label>
            <select id="department" class="form-control"></select>
        </div>

        <div class="col-md-4">
            <label>Section</label>
            <select id="section" class="form-control"></select>
        </div>

        <div class="col-md-12 mt-2">
            <button class="btn btn-primary" onclick="loadTimetable()">View Timetable</button>
        </div>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-bordered text-center align-middle">
            <thead class="table-primary">
                <tr>
                    <th>Day</th>
                    <th>Hour</th>
                    <th>Block</th>
                    <th>Room</th>
                    <th>Subject</th>
                    <th>Faculty</th>
                </tr>
            </thead>
            <tbody id="timetableBody"></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', loadDropdowns);

        async function loadDropdowns() {
            try {
                const url = '@Url.Action("GetMasterData", "Timetable")';
                console.debug('Fetching master data from', url);

                const resp = await fetch(url, { credentials: 'same-origin' });
                const json = await resp.json();

                console.debug('GetMasterData response:', json);

                // Support two shapes:
                // 1) { success: true, data: { batches: [...], ... } }
                // 2) { batches: [...], ... }  (raw)
                const payload = (json && json.data) ? json.data : json;

                if (!payload) {
                    console.warn('No master-data payload received');
                    return;
                }

                fill('batch', payload.batches);
                fill('department', payload.departments);
                fill('section', payload.sections);

                // optional selects that may only exist on AddTimetable form
                fillIfExists('subject', payload.subjects);
                fillIfExists('block', payload.blocks);
                fillIfExists('room', payload.rooms);
                fillIfExists('faculty', payload.faculties);
            } catch (err) {
                console.error('Failed to load master data', err);
            }
        }

        function fill(id, data) {
            const ddl = document.getElementById(id);
            if (!ddl) {
                console.debug(`select #${id} not found in DOM`);
                return;
            }

            ddl.innerHTML = '<option value="">Select</option>';

            if (!data || !Array.isArray(data)) {
                console.debug(`No array data for select #${id}`, data);
                return;
            }

            data.forEach(x => {
                // support items with either { id, name } or { batchId, batchName } forms
                const value = x.id ?? x.batchId ?? x.departmentId ?? x.sectionId ?? x.subjectId ?? x.blockId ?? x.roomId ?? x.FacultyID ?? x.facultyId;
                const text = x.name ?? x.batchName ?? x.departmentName ?? x.sectionName ?? x.subjectName ?? x.blockName ?? x.roomNumber ?? x.FacultyName ?? x.facultyName;
                ddl.insertAdjacentHTML('beforeend', `<option value="${value}">${text}</option>`);
            });
        }

        function fillIfExists(id, data) {
            const el = document.getElementById(id);
            if (!el) return;
            fill(id, data);
        }

        // Keep existing loadTimetable function but use element reads robustly
        function loadTimetable() {
            const batchEl = document.getElementById('batch');
            const deptEl = document.getElementById('department');
            const sectionEl = document.getElementById('section');

            const batchId = batchEl?.value;
            const departmentId = deptEl?.value;
            const sectionId = sectionEl?.value;

            if (!batchId || !departmentId || !sectionId) {
                alert("Select Batch, Department and Section");
                return;
            }

            fetch(`/Timetable/GetTimetableByClass?batchId=${batchId}&departmentId=${departmentId}&sectionId=${sectionId}`)
                .then(r => r.json())
                .then(res => {
                    // server returns { success: true, data } or direct object -> try both
                    const payload = (res && res.data) ? res.data : res;
                    if (!payload) return;

                    const body = document.getElementById('timetableBody');
                    body.innerHTML = '';

                    (payload || []).forEach(x => {
                        body.innerHTML += `
                            <tr>
                                <td>${x.day ?? ''}</td>
                                <td>${x.hour ?? ''}</td>
                                <td>${x.block ?? ''}</td>
                                <td>${x.room ?? ''}</td>
                                <td>${x.subject ?? ''}</td>
                                <td>${x.faculty ?? ''}</td>
                            </tr>
                        `;
                    });
                })
                .catch(e => console.error('loadTimetable failed', e));
        }
    </script>
}