@{
    Layout = "_LayoutWebsite";
    ViewData["Title"] = "View Timetable";
}

<h4 class="fw-bold mb-3">View Timetable</h4>

<div class="card p-3 mb-4">
    <div class="row g-3">

        <div class="col-md-4">
            <label>Batch</label>
            <select id="batch" class="form-control"></select>
        </div>

        <div class="col-md-4">
            <label>Department</label>
            <select id="department" class="form-control"></select>
        </div>

        <div class="col-md-4">
            <label>Section</label>
            <select id="section" class="form-control"></select>
        </div>

        <div class="col-md-12 mt-2">
            <button class="btn btn-primary" onclick="loadTimetable()">View Timetable</button>
        </div>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-bordered text-center align-middle">
            <thead class="table-primary">
                <tr>
                    <th>Day</th>
                    <th>Hour</th>
                    <th>Block</th>
                    <th>Room</th>
                    <th>Subject</th>
                    <th>Faculty</th>
                </tr>
            </thead>
            <tbody id="timetableBody"></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', loadDropdowns);

        function loadDropdowns() {
            fetch('/Timetable/GetDropdowns')
                .then(r => r.json())
                .then(res => {
                    if (!res.success) return;
                    fill('batch', res.data.batches);
                    fill('department', res.data.departments);
                    fill('section', res.data.sections);
                });
        }

        function fill(id, data) {
            const ddl = document.getElementById(id);
            ddl.innerHTML = '<option value="">Select</option>';
            data.forEach(x => {
                ddl.innerHTML += `<option value="${x.id}">${x.name}</option>`;
            });
        }

        function loadTimetable() {
            const batchId = batch.value;
            const departmentId = department.value;
            const sectionId = section.value;

            if (!batchId || !departmentId || !sectionId) {
                alert("Select Batch, Department and Section");
                return;
            }

            fetch(`/Timetable/GetTimetableByClass?batchId=${batchId}&departmentId=${departmentId}&sectionId=${sectionId}`)
                .then(r => r.json())
                .then(res => {
                    if (!res.success) return;

                    const body = document.getElementById('timetableBody');
                    body.innerHTML = '';

                    res.data.forEach(x => {
                        body.innerHTML += `
                            <tr>
                                <td>${x.day}</td>
                                <td>${x.hour}</td>
                                <td>${x.block}</td>
                                <td>${x.room}</td>
                                <td>${x.subject}</td>
                                <td>${x.faculty}</td>
                            </tr>
                        `;
                    });
                });
        }
    </script>
}
